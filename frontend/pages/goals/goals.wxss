/* pages/goals/goals.wxss - 目标管理（微信风格） */

.container {
  padding: 16rpx;
  background: #F5F5F5;
  min-height: 100vh;
  padding-bottom: 200rpx;
}

.card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

/* 统计卡片 */
.stats-row {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #07C160 0%, #09BB66 100%);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 12rpx;
  padding: 12rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.filter-item {
  flex: 1;
  padding: 12rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666666;
  font-weight: 500;
}

.filter-item.active {
  background: #07C160;
  color: #FFFFFF;
}

/* 目标卡片 */
.goal-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.goal-header {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.goal-icon {
  font-size: 48rpx;
}

.goal-info {
  flex: 1;
}

.goal-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 8rpx;
}

.goal-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}

.goal-status {
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.goal-status.active {
  background: rgba(255, 159, 0, 0.1);
  color: #FF9F00;
}

.goal-status.completed {
  background: rgba(7, 193, 96, 0.1);
  color: #07C160;
}

/* 进度条 */
.goal-progress {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background: #EEEEEE;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #07C160;
}

.progress-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #07C160;
  min-width: 72rpx;
  text-align: right;
}

/* 底部 */
.goal-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #EEEEEE;
}

.goal-date {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.date-icon {
  font-size: 24rpx;
}

.date-text {
  font-size: 22rpx;
  color: #999999;
}

.goal-actions {
  display: flex;
  gap: 8rpx;
}

.action-btn {
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.update-btn {
  background: #F5F5F5;
  color: #666666;
}

.complete-btn {
  background: #07C160;
  color: #FFFFFF;
}

/* 浮动按钮 */
.fab-btn {
  position: fixed;
  bottom: 200rpx;
  right: 32rpx;
  width: 96rpx;
  height: 96rpx;
  background: #07C160;
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: #666666;
}

.empty-hint {
  font-size: 24rpx;
  color: #999999;
}

.add-btn {
  padding: 16rpx 32rpx;
  background: #07C160;
  color: #FFFFFF;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
}
