/* pages/learning/path/path.wxss - 学习路径 */
.container {
  padding: 24rpx;
  background: #f5f7fa;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 科目选择 */
.selector-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.subject-tabs {
  display: flex;
  gap: 16rpx;
}

.tab-item {
  flex: 1;
  padding: 20rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  font-weight: 600;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

/* 进度卡片 */
.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.progress-percent {
  font-size: 36rpx;
  font-weight: bold;
  color: #667eea;
}

.progress-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-stats {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

/* 知识点地图 */
.map-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.map-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.map-item {
  border-radius: 12rpx;
  overflow: hidden;
}

.map-item.learned .item-header {
  background: rgba(46, 204, 113, 0.1);
  border-left: 4rpx solid #2ecc71;
}

.map-item.learning .item-header {
  background: rgba(243, 156, 18, 0.1);
  border-left: 4rpx solid #f39c12;
}

.map-item.pending .item-header {
  background: #f5f7fa;
  border-left: 4rpx solid #ddd;
}

.item-header {
  display: flex;
  align-items: center;
  padding: 20rpx;
}

.item-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.item-content {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.item-arrow {
  font-size: 24rpx;
  color: #999;
}

/* 子知识点 */
.item-children {
  padding: 16rpx 20rpx 16rpx 60rpx;
  background: #fafafa;
}

.child-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  margin-bottom: 12rpx;
  background: #fff;
  border-radius: 8rpx;
}

.child-item:last-child {
  margin-bottom: 0;
}

.child-item.learned {
  background: rgba(46, 204, 113, 0.1);
}

.child-item.learning {
  background: rgba(243, 156, 18, 0.1);
}

.child-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 24rpx;
  color: #666;
}

.child-item.learned .child-icon {
  background: #2ecc71;
  color: #fff;
}

.child-item.learning .child-icon {
  background: #f39c12;
  color: #fff;
}

.child-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.child-action {
  padding: 8rpx 16rpx;
  background: #667eea;
  color: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
}

/* 下一步推荐 */
.step-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.step-content {
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  border-radius: 12rpx;
  border-left: 4rpx solid #667eea;
}

.step-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 12rpx;
}

.step-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.step-meta {
  display: flex;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-icon {
  font-size: 28rpx;
}

.meta-text {
  font-size: 26rpx;
  color: #666;
}

.step-action {
  padding: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 12rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}
