/* pages/learning/path/path.wxss - 学习路径（微信风格） */

.container {
  padding: 16rpx;
  background: #F5F5F5;
  min-height: 100vh;
}

.card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

/* 科目选择 */
.selector-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 16rpx;
}

.subject-tabs {
  display: flex;
  gap: 12rpx;
  padding: 12rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.tab-item {
  flex: 1;
  padding: 12rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666666;
  font-weight: 500;
}

.tab-item.active {
  background: #07C160;
  color: #FFFFFF;
}

/* 进度卡片 */
.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
}

.progress-percent {
  font-size: 32rpx;
  font-weight: 600;
  color: #07C160;
}

.progress-bar {
  height: 8rpx;
  background: #EEEEEE;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.progress-fill {
  height: 100%;
  background: #07C160;
}

.progress-stats {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999999;
}

/* 知识点列表 */
.map-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.map-item {
  background: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
}

.map-item.learned .item-header {
  background: rgba(7, 193, 96, 0.08);
  border-left: 4rpx solid #07C160;
}

.map-item.learning .item-header {
  background: rgba(255, 159, 0, 0.08);
  border-left: 4rpx solid #FF9F00;
}

.map-item.pending .item-header {
  background: #FFFFFF;
  border-left: 4rpx solid #EEEEEE;
}

.item-header {
  display: flex;
  align-items: center;
  padding: 20rpx;
}

.item-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.item-content {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-name {
  font-size: 28rpx;
  color: #111111;
  font-weight: 600;
}

.item-arrow {
  font-size: 22rpx;
  color: #CCCCCC;
}

/* 子知识点 */
.item-children {
  padding: 12rpx 16rpx 12rpx 52rpx;
  background: #FAFAFA;
}

.child-item {
  display: flex;
  align-items: center;
  padding: 12rpx;
  margin-bottom: 8rpx;
  background: #FFFFFF;
  border-radius: 8rpx;
}

.child-item:last-child {
  margin-bottom: 0;
}

.child-item.learned {
  background: rgba(7, 193, 96, 0.08);
}

.child-item.learning {
  background: rgba(255, 159, 0, 0.08);
}

.child-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  font-size: 20rpx;
  color: #666666;
}

.child-item.learned .child-icon {
  background: #07C160;
  color: #FFFFFF;
}

.child-item.learning .child-icon {
  background: #FF9F00;
  color: #FFFFFF;
}

.child-name {
  flex: 1;
  font-size: 26rpx;
  color: #111111;
}

.child-action {
  padding: 6rpx 12rpx;
  background: #07C160;
  color: #FFFFFF;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}

/* 下一步推荐 */
.step-content {
  padding: 20rpx;
  background: rgba(7, 193, 96, 0.05);
  border-radius: 12rpx;
  border-left: 4rpx solid #07C160;
}

.step-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #07C160;
  margin-bottom: 8rpx;
}

.step-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.step-action {
  padding: 16rpx;
  background: #07C160;
  color: #FFFFFF;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: #666666;
}

.empty-hint {
  font-size: 24rpx;
  color: #999999;
}
