/* pages/assessment/assessment.wxss - 能力评估（微信风格） */

.container {
  padding: 16rpx;
  background: #F5F5F5;
  min-height: 100vh;
}

.card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

/* 科目选择 */
.selector-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 20rpx;
  text-align: center;
}

.subject-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.subject-item {
  padding: 24rpx 16rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.subject-item:active {
  transform: scale(0.95);
}

.subject-item.active {
  background: #07C160;
}

.subject-item.active .subject-icon {
  filter: brightness(0) invert(1);
}

.subject-item.active .subject-name {
  color: #FFFFFF;
}

.subject-icon {
  font-size: 48rpx;
}

.subject-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #111111;
}

/* 评估介绍 */
.intro-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 16rpx;
}

.intro-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
  margin-bottom: 24rpx;
}

.start-btn {
  width: 100%;
  height: 88rpx;
  background: #07C160;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 12rpx;
}

/* 进度条 */
.progress-section {
  margin-bottom: 24rpx;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.question-count {
  font-size: 26rpx;
  color: #666666;
}

.progress-percent {
  font-size: 26rpx;
  font-weight: 600;
  color: #07C160;
}

.progress-bar {
  height: 8rpx;
  background: #EEEEEE;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #07C160;
}

/* 题目区域 */
.question-section {
  margin-bottom: 24rpx;
}

.question-type {
  font-size: 24rpx;
  color: #07C160;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.question-content {
  font-size: 30rpx;
  color: #111111;
  line-height: 1.8;
  margin-bottom: 24rpx;
}

/* 选项 */
.options-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.option-item {
  padding: 20rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border: 1rpx solid #EEEEEE;
}

.option-item:active {
  background: #FAFAFA;
}

.option-item.selected {
  border-color: #07C160;
  background: rgba(7, 193, 96, 0.05);
}

.option-mark {
  width: 44rpx;
  height: 44rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #666666;
  border: 2rpx solid #EEEEEE;
}

.option-item.selected .option-mark {
  background: #07C160;
  color: #FFFFFF;
  border-color: #07C160;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #111111;
}

/* 操作按钮 */
.action-section {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.action-btn:active {
  opacity: 0.8;
}

.prev-btn {
  background: #F5F5F5;
  color: #666666;
}

.next-btn {
  background: #07C160;
  color: #FFFFFF;
}

/* 结果页面 */
.result-header {
  text-align: center;
  margin-bottom: 24rpx;
}

.result-emoji {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111111;
}

/* 分数圆圈 */
.score-section {
  text-align: center;
  margin-bottom: 24rpx;
}

.score-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #07C160;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
}

.score-value {
  font-size: 48rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.score-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 结果详情 */
.result-details {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.detail-item {
  padding: 20rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-label {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.detail-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #111111;
}

.detail-value.good {
  color: #07C160;
}

.detail-value.normal {
  color: #FF9F00;
}

.detail-value.poor {
  color: #FA5151;
}

/* 结果操作 */
.result-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.view-report-btn,
.retake-btn {
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.view-report-btn {
  background: #07C160;
  color: #FFFFFF;
}

.retake-btn {
  background: #F5F5F5;
  color: #666666;
}
