/* pages/assessment/assessment.wxss - 能力评估 */
.container {
  padding: 24rpx;
  background: #f5f7fa;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 科目选择 */
.selector-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  text-align: center;
}

.subject-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.subject-item {
  padding: 32rpx 16rpx;
  background: #f5f7fa;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  transition: all 0.3s;
}

.subject-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  transform: translateY(-4rpx);
}

.subject-icon {
  font-size: 64rpx;
}

.subject-name {
  font-size: 28rpx;
  font-weight: 600;
}

/* 评估介绍 */
.intro-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.intro-content {
  margin-bottom: 32rpx;
}

.intro-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 2;
  margin-bottom: 8rpx;
}

.start-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

/* 进度条 */
.progress-section {
  margin-bottom: 32rpx;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.question-count {
  font-size: 28rpx;
  color: #666;
}

.progress-percent {
  font-size: 28rpx;
  font-weight: bold;
  color: #667eea;
}

.progress-bar {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  transition: width 0.3s ease;
}

/* 题目区域 */
.question-section {
  margin-bottom: 32rpx;
}

.question-type {
  font-size: 24rpx;
  color: #667eea;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.question-content {
  font-size: 32rpx;
  color: #333;
  line-height: 1.8;
  margin-bottom: 32rpx;
}

/* 选项 */
.options-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  padding: 24rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  transition: all 0.3s;
}

.option-item.selected {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  border: 2rpx solid #667eea;
}

.option-mark {
  width: 48rpx;
  height: 48rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #667eea;
  border: 2rpx solid #667eea;
}

.option-item.selected .option-mark {
  background: #667eea;
  color: #fff;
}

.option-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

/* 输入框 */
.input-section {
  margin-top: 24rpx;
}

.answer-input {
  width: 100%;
  padding: 24rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

/* 操作按钮 */
.action-section {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.prev-btn {
  background: #f5f7fa;
  color: #666;
}

.prev-btn[disabled] {
  opacity: 0.5;
}

.next-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.next-btn[disabled] {
  opacity: 0.5;
}

/* 结果页面 */
.result-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.result-emoji {
  font-size: 100rpx;
  display: block;
  margin-bottom: 16rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 分数圆圈 */
.score-section {
  text-align: center;
  margin-bottom: 32rpx;
}

.score-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.score-value {
  font-size: 64rpx;
  font-weight: bold;
  color: #fff;
}

.score-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 结果详情 */
.result-details {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.detail-item {
  padding: 24rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.detail-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.detail-value.good {
  color: #27ae60;
}

.detail-value.normal {
  color: #f39c12;
}

/* 结果操作 */
.result-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.view-report-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.retake-btn {
  background: #f5f7fa;
  color: #666;
}
