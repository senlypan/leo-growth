/* pages/assessment/report/report.wxss - 评估报告 */
.container {
  padding: 24rpx;
  background: #f5f7fa;
  min-height: 100vh;
  padding-bottom: 200rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* 报告头部 */
.report-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.subject-icon {
  font-size: 80rpx;
}

.header-text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.subject-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.report-date {
  font-size: 24rpx;
  color: #999;
}

.score-section {
  display: flex;
  align-items: center;
}

.score-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.score-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
}

.score-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 雷达图 */
.radar-chart {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.radar-canvas {
  width: 500rpx;
  height: 500rpx;
}

.radar-legend {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.legend-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
}

.legend-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.legend-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #667eea;
}

/* 优势分析 */
.strength-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.strength-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.strength-icon {
  font-size: 40rpx;
}

.strength-content {
  width: 200rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.strength-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.strength-score {
  font-size: 24rpx;
  color: #666;
}

.strength-bar {
  flex: 1;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.strength-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

/* 薄弱点 */
.weakness-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.weakness-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 20rpx;
  background: #fff8e8;
  border-radius: 12rpx;
  border-left: 4rpx solid #f39c12;
}

.weakness-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.weakness-icon {
  font-size: 40rpx;
}

.weakness-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.weakness-score {
  font-size: 24rpx;
  color: #f39c12;
  font-weight: bold;
}

.weakness-suggestion {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  padding-left: 56rpx;
}

/* 学习建议 */
.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx;
  background: #e8f4ff;
  border-radius: 12rpx;
  border-left: 4rpx solid #3498db;
}

.suggestion-icon {
  font-size: 40rpx;
}

.suggestion-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

/* 操作按钮 */
.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  display: flex;
  gap: 16rpx;
  z-index: 100;
}

.action-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.retake-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.back-btn {
  background: #f5f7fa;
  color: #666;
}
