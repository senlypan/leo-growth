/* pages/assessment/report/report.wxss - 评估报告（微信风格） */

.container {
  padding: 16rpx;
  background: #F5F5F5;
  min-height: 100vh;
  padding-bottom: 200rpx;
}

.card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

/* 报告头部 */
.report-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.subject-icon {
  font-size: 64rpx;
}

.subject-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #111111;
}

.report-date {
  font-size: 22rpx;
  color: #999999;
}

.score-section {
  display: flex;
  align-items: center;
}

.score-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #07C160;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-value {
  font-size: 48rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.score-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 优势分析 */
.strength-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.strength-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.strength-icon {
  font-size: 36rpx;
}

.strength-content {
  width: 180rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.strength-name {
  font-size: 26rpx;
  color: #111111;
  font-weight: 600;
}

.strength-score {
  font-size: 22rpx;
  color: #666666;
}

.strength-bar {
  flex: 1;
  height: 8rpx;
  background: #EEEEEE;
  border-radius: 4rpx;
  overflow: hidden;
}

.strength-fill {
  height: 100%;
  background: #07C160;
}

/* 薄弱点 */
.weakness-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.weakness-item {
  padding: 16rpx;
  background: rgba(255, 159, 0, 0.08);
  border-radius: 8rpx;
  border-left: 4rpx solid #FF9F00;
}

.weakness-content {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.weakness-icon {
  font-size: 36rpx;
}

.weakness-name {
  flex: 1;
  font-size: 26rpx;
  color: #111111;
  font-weight: 600;
}

.weakness-score {
  font-size: 22rpx;
  color: #FF9F00;
  font-weight: 600;
}

.weakness-suggestion {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
  padding-left: 48rpx;
}

/* 学习建议 */
.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 16rpx;
  background: rgba(16, 174, 255, 0.08);
  border-radius: 8rpx;
  border-left: 4rpx solid #10AEFF;
}

.suggestion-icon {
  font-size: 36rpx;
}

.suggestion-text {
  flex: 1;
  font-size: 26rpx;
  color: #111111;
  line-height: 1.6;
}

/* 操作按钮 */
.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx;
  background: #FFFFFF;
  display: flex;
  gap: 12rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.action-btn:active {
  opacity: 0.8;
}

.retake-btn {
  background: #07C160;
  color: #FFFFFF;
}

.back-btn {
  background: #F5F5F5;
  color: #666666;
}
