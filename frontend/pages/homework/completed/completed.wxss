/* pages/homework/completed/completed.wxss - 作业完成页 */

.page {
  padding: var(--space-3);
  padding-bottom: 200rpx;
}

/* 完成头部 */
.completed-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-5) 0;
  text-align: center;
}

.completed-icon {
  font-size: 120rpx;
  margin-bottom: var(--space-3);
  animation: bounce 0.6s ease;
}

.completed-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-1);
  margin-bottom: var(--space-1);
}

.completed-subtitle {
  font-size: 26rpx;
  color: var(--text-3);
}

@keyframes bounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

/* 结果卡片 */
.result-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  margin-bottom: var(--space-2);
  box-shadow: var(--shadow-sm);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-3);
  padding-bottom: var(--space-2);
  border-bottom: 1rpx solid var(--border-light);
}

.result-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-1);
}

.result-score {
  display: flex;
  align-items: baseline;
  padding: var(--space-1) var(--space-2);
  background: rgba(7, 193, 96, 0.1);
  border-radius: var(--radius-md);
}

.result-score.excellent {
  background: rgba(7, 193, 96, 0.1);
}

.result-score.good {
  background: rgba(255, 159, 0, 0.1);
}

.result-score.need-improve {
  background: rgba(250, 81, 81, 0.1);
}

.result-score text:first-child {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--primary);
}

.result-score.excellent text:first-child {
  color: var(--primary);
}

.result-score.good text:first-child {
  color: #FF9F00;
}

.result-score.need-improve text:first-child {
  color: #FA5151;
}

.score-unit {
  font-size: 24rpx !important;
  font-weight: 400 !important;
  margin-left: 4rpx;
}

.result-content {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.result-item-label {
  font-size: 26rpx;
  color: var(--text-2);
}

.result-item-value {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-1);
}

/* 评语区域 */
.comment-section {
  margin-top: var(--space-3);
  padding-top: var(--space-3);
  border-top: 1rpx solid var(--border-light);
}

.comment-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-2);
  margin-bottom: var(--space-2);
}

.comment-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-1);
  background: var(--bg-3);
  padding: var(--space-2);
  border-radius: var(--radius-md);
}

/* 积分卡片 */
.points-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  margin-bottom: var(--space-2);
  box-shadow: var(--shadow-sm);
}

.points-header {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  margin-bottom: var(--space-3);
}

.points-icon {
  font-size: 40rpx;
}

.points-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-1);
}

.points-body {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.points-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-2);
  background: var(--bg-3);
  border-radius: var(--radius-md);
}

.points-item-label {
  font-size: 26rpx;
  color: var(--text-2);
}

.points-item-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
}

.points-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-2);
  background: linear-gradient(135deg, #07C160 0%, #08B85F 100%);
  border-radius: var(--radius-md);
  margin-top: var(--space-2);
}

.points-total-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.points-total-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* 下一步操作 */
.actions-section {
  margin-bottom: var(--space-3);
}

.actions-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-1);
  margin-bottom: var(--space-2);
}

.actions-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.action-item {
  display: flex;
  align-items: center;
  padding: var(--space-3);
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
}

.action-item:active {
  transform: scale(0.98);
  background: var(--bg-3);
}

.action-icon {
  font-size: 40rpx;
  margin-right: var(--space-2);
}

.action-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.action-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-1);
}

.action-desc {
  font-size: 24rpx;
  color: var(--text-3);
}

.action-arrow {
  font-size: 40rpx;
  color: var(--text-3);
}

/* 底部按钮 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: var(--space-2);
  padding: var(--space-3);
  background: #FFFFFF;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.bottom-actions button {
  flex: 1;
  height: 88rpx;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.bottom-actions .btn-secondary {
  background: var(--bg-3);
  color: var(--text-1);
}

.bottom-actions .btn-primary {
  background: var(--primary);
  color: #FFFFFF;
}
