/* pages/homework/submission/submission.wxss - 提交记录（微信风格） */

.container {
  padding: 16rpx;
  background: #F5F5F5;
  min-height: 100vh;
}

.card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

/* 提交列表 */
.submission-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.submission-item {
  padding: 20rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  border: 1rpx solid #EEEEEE;
}

.submission-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.submission-time {
  font-size: 22rpx;
  color: #999999;
}

.submission-status {
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.submission-status.pending {
  background: rgba(255, 159, 0, 0.1);
  color: #FF9F00;
}

.submission-status.correct {
  background: rgba(7, 193, 96, 0.1);
  color: #07C160;
}

.submission-status.incorrect {
  background: rgba(250, 81, 81, 0.1);
  color: #FA5151;
}

.submission-content {
  font-size: 26rpx;
  color: #111111;
  line-height: 1.6;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 32rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 26rpx;
  color: #666666;
}
