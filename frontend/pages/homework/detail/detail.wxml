<!--pages/homework/detail/detail.wxml - 作业详情页-->
<view class="page">
  <!-- 加载状态 -->
  <view class="loading" wx:if="{{isLoading}}">
    <text>加载中...</text>
  </view>

  <!-- 作业内容 -->
  <view class="homework-card" wx:else>
    <view class="homework-header">
      <view class="subject-badge {{homework.subject}}">{{homework.subjectName}}</view>
      <view class="status-badge {{homework.status}}">{{homework.statusText}}</view>
    </view>

    <view class="homework-content">
      <text class="content-label">作业内容</text>
      <text class="content-text">{{homework.content}}</text>
    </view>

    <view class="homework-meta">
      <view class="meta-item">
        <text class="meta-label">截止时间</text>
        <text class="meta-value">{{homework.deadline}}</text>
      </view>
      <view class="meta-item">
        <text class="meta-label">创建时间</text>
        <text class="meta-value">{{homework.createTime}}</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <button class="btn-secondary" bindtap="goBack">返回</button>
    
    <button class="btn-primary" wx:if="{{homework.status === 'pending'}}" bindtap="submitHomework">
      完成作业
    </button>
    
    <button class="btn-primary" wx:if="{{homework.status === 'submitted'}}" bindtap="checkHomework">
      批改作业
    </button>
    
    <button class="btn-success" wx:if="{{homework.status === 'checked'}}" bindtap="viewResult">
      查看结果
    </button>
  </view>
</view>
