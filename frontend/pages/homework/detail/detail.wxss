/* pages/homework/detail/detail.wxss - 作业详情页 */

.page {
  padding: var(--space-3);
  padding-bottom: 200rpx;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-6) 0;
  color: var(--text-3);
}

.homework-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  margin-bottom: var(--space-2);
  box-shadow: var(--shadow-sm);
}

.homework-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-3);
}

.subject-badge {
  padding: 6rpx 12rpx;
  background: rgba(7, 193, 96, 0.1);
  color: var(--primary);
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-weight: 500;
}

.status-badge {
  padding: 6rpx 12rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-weight: 500;
}

.status-badge.pending {
  background: rgba(255, 159, 0, 0.1);
  color: #FF9F00;
}

.status-badge.completed {
  background: rgba(7, 193, 96, 0.1);
  color: var(--primary);
}

.status-badge.submitted {
  background: rgba(16, 174, 255, 0.1);
  color: #10AEFF;
}

.status-badge.checked {
  background: rgba(7, 193, 96, 0.1);
  color: var(--primary);
}

.homework-content {
  margin-bottom: var(--space-3);
}

.content-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-3);
  margin-bottom: var(--space-2);
}

.content-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-1);
  background: var(--bg-3);
  padding: var(--space-2);
  border-radius: var(--radius-md);
}

.homework-meta {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  padding-top: var(--space-2);
  border-top: 1rpx solid var(--border-light);
}

.meta-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.meta-label {
  font-size: 24rpx;
  color: var(--text-3);
}

.meta-value {
  font-size: 24rpx;
  color: var(--text-1);
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: var(--space-2);
  padding: var(--space-3);
  background: #FFFFFF;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.action-bar button {
  flex: 1;
  height: 88rpx;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.btn-secondary {
  background: var(--bg-3);
  color: var(--text-1);
}

.btn-primary {
  background: var(--primary);
  color: #FFFFFF;
}

.btn-success {
  background: var(--primary);
  color: #FFFFFF;
}
