<!--pages/homework/homework.wxml - 高级极简版-->
<view class="page">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="page-title-row">
      <text class="page-title">作业辅导</text>
      <view class="add-btn" bindtap="addHomework">
        <text>+</text>
      </view>
    </view>
    <text class="page-subtitle">智能管理，高效完成</text>
  </view>

  <!-- 日期选择 - 极简 -->
  <view class="date-selector">
    <view class="date-item {{selectedDate === today ? 'active' : ''}}" bindtap="selectDate" data-date="{{today}}">
      <text class="date-text">今天</text>
      <text class="date-sub">{{todayStr}}</text>
    </view>
    <view class="date-item {{selectedDate === tomorrow ? 'active' : ''}}" bindtap="selectDate" data-date="{{tomorrow}}">
      <text class="date-text">明天</text>
      <text class="date-sub">{{tomorrowStr}}</text>
    </view>
    <view class="date-item" bindtap="showDatePicker">
      <text class="date-text">选择</text>
      <text class="date-sub">日期</text>
    </view>
  </view>

  <!-- 筛选栏 - 极简 -->
  <view class="filter-bar">
    <view class="filter-item {{currentSubject === 'all' ? 'active' : ''}}" bindtap="selectSubject" data-subject="all">全部</view>
    <view class="filter-item {{currentSubject === 'chinese' ? 'active' : ''}}" bindtap="selectSubject" data-subject="chinese">语文</view>
    <view class="filter-item {{currentSubject === 'math' ? 'active' : ''}}" bindtap="selectSubject" data-subject="math">数学</view>
    <view class="filter-item {{currentSubject === 'english' ? 'active' : ''}}" bindtap="selectSubject" data-subject="english">英语</view>
  </view>

  <!-- 作业列表 -->
  <view class="homework-list" wx:if="{{homeworkList.length > 0}}">
    <view class="homework-card {{item.subject}}" wx:for="{{homeworkList}}" wx:key="id">
      <view class="homework-card-header">
        <view class="subject-badge {{item.subject}}">{{item.subjectName}}</view>
        <view class="status-badge {{item.status}}">{{item.statusText}}</view>
      </view>
      <view class="homework-card-content">
        <text class="homework-card-text">{{item.content}}</text>
      </view>
      <view class="homework-card-footer">
        <view class="homework-card-time">
          <text class="time-text">{{item.createTime}}</text>
        </view>
        <view class="homework-card-actions">
          <view class="action-btn submit-btn" wx:if="{{item.status === 'pending'}}" bindtap="submitHomework" data-id="{{item.id}}">提交</view>
          <view class="action-btn view-btn" bindtap="viewDetail" data-id="{{item.id}}">查看</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:else>
    <text class="empty-title">暂无作业</text>
    <text class="empty-desc">好好休息一下吧</text>
  </view>
</view>
