<!--pages/homework/check/check.wxml - 家长批改页-->
<view class="page">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">批改作业</text>
    <text class="page-subtitle">AI 辅助，快速批改</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{isLoading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">AI 批改中...</text>
  </view>

  <!-- 批改内容 -->
  <view class="check-content" wx:else>
    <!-- 作业信息 -->
    <view class="homework-card">
      <view class="homework-header">
        <view class="subject-badge {{homework.subject}}">{{homework.subjectName}}</view>
        <text class="homework-time">{{homework.submitTime}}</text>
      </view>
      <view class="homework-content">
        <text class="content-label">作业内容</text>
        <text class="content-text">{{homework.content}}</text>
      </view>
    </view>

    <!-- 提交的照片 -->
    <view class="photos-section" wx:if="{{homework.images && homework.images.length > 0}}">
      <text class="section-label">提交的照片</text>
      <view class="photos-grid">
        <image class="photo-item" wx:for="{{homework.images}}" wx:key="*this" 
               src="{{item}}" mode="aspectFill" 
               bindtap="previewImage" data-src="{{item}}" />
      </view>
    </view>

    <!-- AI 批改结果 -->
    <view class="ai-result">
      <view class="result-header">
        <text class="result-label">🤖 AI 批改建议</text>
        <view class="ai-badge">AI 辅助</view>
      </view>
      
      <view class="result-body">
        <view class="result-row">
          <text class="result-key">正确率</text>
          <text class="result-value {{aiResult.scoreClass}}">{{aiResult.accuracy}}%</text>
        </view>
        <view class="result-row">
          <text class="result-key">建议评分</text>
          <text class="result-value">{{aiResult.suggestedScore}} 分</text>
        </view>
        <view class="result-row">
          <text class="result-key">问题诊断</text>
          <text class="result-text">{{aiResult.diagnosis}}</text>
        </view>
      </view>
    </view>

    <!-- 家长评分 -->
    <view class="parent-check">
      <text class="section-label">家长批改</text>
      
      <!-- 评分 -->
      <view class="score-input">
        <text class="score-label">评分</text>
        <view class="score-selector">
          <input class="score-input-field" type="number" 
                 value="{{score}}" placeholder="0-100"
                 bindinput="onScoreChange" />
          <text class="score-unit">分</text>
        </view>
      </view>

      <!-- 批改结果 -->
      <view class="check-result-selector">
        <text class="score-label">批改结果</text>
        <view class="result-options">
          <view class="result-option {{checkResult === 'correct' ? 'active' : ''}}" 
                bindtap="selectCheckResult" data-result="correct">
            <text>✅ 正确</text>
          </view>
          <view class="result-option {{checkResult === 'wrong' ? 'active' : ''}}" 
                bindtap="selectCheckResult" data-result="wrong">
            <text>❌ 有错误</text>
          </view>
        </view>
      </view>

      <!-- 评语 -->
      <view class="comment-input">
        <text class="score-label">评语（可选）</text>
        <textarea class="comment-textarea" 
                  value="{{comment}}" 
                  placeholder="写点鼓励的话吧～"
                  maxlength="200"
                  bindinput="onCommentChange" />
      </view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="action-bar" wx:if="{{!isLoading}}">
    <button class="btn-submit" bindtap="submitCheck">提交批改</button>
  </view>
</view>
