/* pages/homework/check/check.wxss - 家长批改页 */

.page {
  padding: var(--space-3);
  padding-bottom: 200rpx;
}

.page-header {
  margin-bottom: var(--space-4);
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-6) 0;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: var(--space-3);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-3);
}

/* 作业卡片 */
.homework-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  margin-bottom: var(--space-2);
  box-shadow: var(--shadow-sm);
}

.homework-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-2);
}

.subject-badge {
  padding: 6rpx 12rpx;
  background: rgba(7, 193, 96, 0.1);
  color: var(--primary);
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-weight: 500;
}

.homework-time {
  font-size: 24rpx;
  color: var(--text-3);
}

.homework-content {
  margin-bottom: var(--space-2);
}

.content-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-3);
  margin-bottom: var(--space-2);
}

.content-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-1);
  background: var(--bg-3);
  padding: var(--space-2);
  border-radius: var(--radius-md);
}

/* 照片区域 */
.photos-section {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  margin-bottom: var(--space-2);
  box-shadow: var(--shadow-sm);
}

.section-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-1);
  margin-bottom: var(--space-2);
}

.photos-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-2);
}

.photo-item {
  width: 100%;
  aspect-ratio: 1;
  border-radius: var(--radius-md);
  background: var(--bg-3);
}

/* AI 批改结果 */
.ai-result {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  margin-bottom: var(--space-2);
  box-shadow: var(--shadow-sm);
  border: 2rpx solid rgba(7, 193, 96, 0.2);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-3);
}

.result-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-1);
}

.ai-badge {
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #07C160 0%, #08B85F 100%);
  color: #FFFFFF;
  border-radius: var(--radius-sm);
  font-size: 20rpx;
  font-weight: 500;
}

.result-body {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.result-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-2);
  background: var(--bg-3);
  border-radius: var(--radius-md);
}

.result-key {
  font-size: 26rpx;
  color: var(--text-2);
}

.result-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-1);
}

.result-value.excellent {
  color: var(--primary);
}

.result-value.good {
  color: #FF9F00;
}

.result-value.need-improve {
  color: #FA5151;
}

.result-text {
  font-size: 26rpx;
  color: var(--text-2);
  text-align: right;
}

/* 家长批改 */
.parent-check {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  margin-bottom: var(--space-2);
  box-shadow: var(--shadow-sm);
}

.score-input {
  margin-bottom: var(--space-3);
}

.score-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-1);
  margin-bottom: var(--space-2);
}

.score-selector {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.score-input-field {
  flex: 1;
  padding: var(--space-2);
  background: var(--bg-3);
  border-radius: var(--radius-md);
  font-size: 30rpx;
  text-align: center;
}

.score-unit {
  font-size: 28rpx;
  color: var(--text-2);
}

/* 批改结果选择 */
.check-result-selector {
  margin-bottom: var(--space-3);
}

.result-options {
  display: flex;
  gap: var(--space-2);
}

.result-option {
  flex: 1;
  padding: var(--space-3);
  background: var(--bg-3);
  border-radius: var(--radius-md);
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-2);
  transition: all 0.2s ease;
}

.result-option:active {
  opacity: 0.7;
}

.result-option.active {
  background: var(--primary);
  color: #FFFFFF;
}

/* 评语输入 */
.comment-input {
  margin-bottom: var(--space-2);
}

.comment-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: var(--space-2);
  background: var(--bg-3);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  line-height: 1.6;
}

/* 提交按钮 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--space-3);
  background: #FFFFFF;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  background: var(--primary);
  color: #FFFFFF;
  border-radius: var(--radius-lg);
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.btn-submit:active {
  opacity: 0.7;
}
