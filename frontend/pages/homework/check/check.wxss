/* pages/homework/check/check.wxss - 检查作业 */
.container {
  padding: 24rpx;
  background: #f5f7fa;
  min-height: 100vh;
  padding-bottom: 200rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* 作业卡片 */
.homework-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.subject-badge {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.subject-badge.chinese {
  background: #ffe8e8;
  color: #e74c3c;
}

.subject-badge.math {
  background: #e8f4ff;
  color: #3498db;
}

.subject-badge.english {
  background: #fff8e8;
  color: #f39c12;
}

.status-badge {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.status-badge.pending {
  background: #fff8e8;
  color: #f39c12;
}

.status-badge.completed {
  background: #e8ffe8;
  color: #27ae60;
}

.status-badge.checked {
  background: #e8f4ff;
  color: #3498db;
}

.homework-content {
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.content-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.content-text {
  display: block;
  font-size: 32rpx;
  color: #333;
  line-height: 1.6;
}

/* 提交卡片 */
.submission-info {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 16rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 12rpx;
  font-weight: 600;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

/* 图片画廊 */
.image-gallery {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.gallery-image {
  width: 100%;
  border-radius: 12rpx;
  background: #f5f7fa;
}

/* 学生说明 */
.student-note {
  padding: 24rpx;
  background: #fff8e8;
  border-radius: 12rpx;
  border-left: 4rpx solid #f39c12;
}

.note-title {
  font-size: 28rpx;
  color: #f39c12;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.note-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

/* 检查区域 */
.check-section {
  margin-bottom: 32rpx;
}

.check-section:last-child {
  margin-bottom: 0;
}

.section-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  font-weight: 600;
}

/* 单选组 */
.radio-group {
  display: flex;
  gap: 20rpx;
}

.radio-item {
  flex: 1;
  padding: 24rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  transition: all 0.3s;
}

.radio-item.active.correct {
  background: #e8ffe8;
  border: 2rpx solid #27ae60;
}

.radio-item.active.incorrect {
  background: #ffe8e8;
  border: 2rpx solid #e74c3c;
}

.radio-circle {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.radio-item.active .radio-circle {
  border-color: currentColor;
}

.radio-item.correct .radio-circle {
  border-color: #27ae60;
}

.radio-item.incorrect .radio-circle {
  border-color: #e74c3c;
}

.radio-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: currentColor;
}

.radio-item.correct .radio-dot {
  background: #27ae60;
}

.radio-item.incorrect .radio-dot {
  background: #e74c3c;
}

.radio-label {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

/* 评分选择器 */
.score-selector {
  display: flex;
  gap: 16rpx;
}

.score-item {
  padding: 16rpx 24rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  font-size: 40rpx;
  transition: all 0.3s;
}

.score-item.active {
  background: linear-gradient(135deg, #f39c12 0%, #e74c3c 100%);
  transform: scale(1.1);
}

.score-item.active text {
  filter: brightness(0) invert(1);
}

/* 反馈输入 */
.feedback-input {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  font-size: 30rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

/* 操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.action-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.action-btn[disabled] {
  background: #ccc;
  box-shadow: none;
}
