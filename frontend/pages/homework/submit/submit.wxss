/* pages/homework/submit/submit.wxss - 提交作业（微信风格） */

.container {
  padding: 16rpx;
  background: #F5F5F5;
  min-height: 100vh;
  padding-bottom: 200rpx;
}

.card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.form-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 16rpx;
}

/* 上传区域 */
.upload-section {
  margin-bottom: 24rpx;
}

.image-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.image-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: 8rpx;
  overflow: hidden;
  background: #FFFFFF;
}

.image-preview {
  width: 100%;
  height: 100%;
}

.image-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 24rpx;
}

.upload-btn {
  width: 100%;
  height: 240rpx;
  background: #FFFFFF;
  border: 2rpx dashed #EEEEEE;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
  color: #CCCCCC;
}

.upload-text {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
}

.upload-hint {
  font-size: 22rpx;
  color: #999999;
}

/* 输入框 */
.note-input {
  width: 100%;
  min-height: 160rpx;
  padding: 16rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.6;
  border: 1rpx solid #EEEEEE;
}

/* 提示区域 */
.tips-section {
  margin-top: 24rpx;
  padding: 16rpx;
  background: rgba(255, 159, 0, 0.08);
  border-radius: 8rpx;
  border-left: 4rpx solid #FF9F00;
}

.tips-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #FF9F00;
  margin-bottom: 12rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

/* 操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx;
  background: #FFFFFF;
}

.btn {
  width: 100%;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn:active {
  opacity: 0.8;
}

.btn-primary {
  background: #07C160;
  color: #FFFFFF;
}

.btn-primary.disabled {
  background: #CCCCCC;
}
