<!--pages/homework/submit/submit.wxml - 提交作业-->
<view class="container">
  <view class="form-card card">
    <view class="form-title">📸 拍照上传</view>
    
    <view class="upload-section">
      <!-- 已上传的图片 -->
      <view class="image-list" wx:if="{{images.length > 0}}">
        <view class="image-item" wx:for="{{images}}" wx:key="*this">
          <image class="image-preview" 
                 src="{{item}}" 
                 mode="aspectFill"
                 bindtap="previewImage"
                 data-index="{{index}}"></image>
          <view class="image-delete" bindtap="deleteImage" data-index="{{index}}">
            <text>✕</text>
          </view>
        </view>
      </view>
      
      <!-- 上传按钮 -->
      <view class="upload-btn" bindtap="chooseImage">
        <text class="upload-icon">📷</text>
        <text class="upload-text">点击拍照</text>
        <text class="upload-hint">支持多张照片</text>
      </view>
    </view>

    <view class="form-title mt-4">📝 文字说明（可选）</view>
    
    <textarea 
      class="note-input"
      placeholder="写下你的想法或疑问..."
      maxlength="500"
      value="{{note}}"
      bindinput="onNoteInput"
      auto-height
    ></textarea>

    <view class="tips-section">
      <text class="tips-title">💡 温馨提示：</text>
      <text class="tips-text">1. 请确保照片清晰，能够看清题目和答案</text>
      <text class="tips-text">2. 可以上传多张照片，全面展示作业</text>
      <text class="tips-text">3. 如果有疑问，可以在文字说明中描述</text>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="action-bar">
    <view class="btn btn-primary {{canSubmit ? '' : 'disabled'}}" bindtap="submitHomework">
      <text>{{isResubmit ? '🔄 重新提交' : '✅ 提交作业'}}</text>
    </view>
  </view>
</view>
