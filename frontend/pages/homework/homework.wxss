/* pages/homework/homework.wxss - 高级极简版 */

.page-header {
  margin-bottom: var(--space-4);
}

.page-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-1);
}

.add-btn {
  width: 56rpx;
  height: 56rpx;
  background: var(--primary);
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 300;
  transition: all 0.2s ease;
}

.add-btn:active {
  transform: scale(0.9);
}

/* 日期选择 - 极简 */
.date-selector {
  display: flex;
  gap: var(--space-2);
  margin-bottom: var(--space-3);
  background: #FFFFFF;
  padding: var(--space-2);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.date-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-2);
  border-radius: var(--radius-md);
  transition: all 0.2s ease;
}

.date-item:active {
  background: var(--bg-3);
}

.date-item.active {
  background: var(--primary);
}

.date-item.active .date-text,
.date-item.active .date-sub {
  color: #FFFFFF;
}

.date-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-1);
  margin-bottom: 4rpx;
}

.date-sub {
  font-size: 22rpx;
  color: var(--text-3);
}

/* 筛选栏 - 极简 */
.filter-bar {
  display: flex;
  gap: var(--space-2);
  margin-bottom: var(--space-3);
  overflow-x: auto;
  padding: var(--space-1);
}

.filter-item {
  flex-shrink: 0;
  padding: var(--space-2) var(--space-3);
  background: #FFFFFF;
  border-radius: var(--radius-md);
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-2);
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
}

.filter-item:active {
  opacity: 0.7;
}

.filter-item.active {
  background: var(--primary);
  color: #FFFFFF;
}

/* 作业卡片 - 极简 */
.homework-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.homework-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  box-shadow: var(--shadow-sm);
  position: relative;
  overflow: hidden;
}

.homework-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 6rpx;
  height: 100%;
}

.homework-card.chinese::before {
  background: #FA5151;
}

.homework-card.math::before {
  background: #10AEFF;
}

.homework-card.english::before {
  background: #FF9F00;
}

.homework-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-2);
}

.subject-badge {
  padding: 6rpx 12rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-weight: 500;
  background: var(--bg-3);
  color: var(--text-2);
}

.status-badge {
  padding: 6rpx 12rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-weight: 500;
}

.status-badge.pending {
  background: rgba(255, 159, 0, 0.08);
  color: #FF9F00;
}

.status-badge.completed {
  background: rgba(7, 193, 96, 0.08);
  color: var(--primary);
}

.homework-card-content {
  margin-bottom: var(--space-3);
}

.homework-card-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--text-1);
  background: var(--bg-3);
  padding: var(--space-2);
  border-radius: var(--radius-md);
}

.homework-card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: var(--space-2);
  border-top: 1rpx solid var(--border-light);
}

.time-text {
  font-size: 24rpx;
  color: var(--text-3);
}

.homework-card-actions {
  display: flex;
  gap: var(--space-2);
}

.action-btn {
  padding: var(--space-1) var(--space-2);
  border-radius: var(--radius-md);
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.action-btn:active {
  opacity: 0.7;
}

.submit-btn {
  background: var(--primary);
  color: #FFFFFF;
}

.view-btn {
  background: var(--bg-3);
  color: var(--text-1);
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-6) var(--space-4);
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}
