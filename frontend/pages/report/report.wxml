<!--pages/report/report.wxml - 学习报告-->
<view class="container">
  <!-- 顶部选择器 -->
  <view class="period-selector card">
    <view class="period-item {{currentPeriod === 'weekly' ? 'active' : ''}}" 
          bindtap="selectPeriod" data-period="weekly">
      <text>本周</text>
    </view>
    <view class="period-item {{currentPeriod === 'monthly' ? 'active' : ''}}" 
          bindtap="selectPeriod" data-period="monthly">
      <text>本月</text>
    </view>
    <view class="period-item" bindtap="selectDateRange">
      <text>📅 自定义</text>
    </view>
  </view>

  <!-- 学习概览 -->
  <view class="overview-card card">
    <view class="card-title">📈 学习概览</view>
    <view class="overview-grid">
      <view class="overview-item">
        <text class="item-value {{overview.totalHomework > 0 ? 'highlight' : ''}}">{{overview.totalHomework}}</text>
        <text class="item-label">总作业</text>
      </view>
      <view class="overview-item">
        <text class="item-value {{overview.completionRate >= 80 ? 'highlight' : ''}}">{{overview.completionRate}}%</text>
        <text class="item-label">完成率</text>
      </view>
      <view class="overview-item">
        <text class="item-value {{overview.avgScore >= 85 ? 'highlight' : ''}}">{{overview.avgScore}}</text>
        <text class="item-label">平均分</text>
      </view>
      <view class="overview-item">
        <text class="item-value {{overview.mistakeReviewRate >= 70 ? 'highlight' : ''}}">{{overview.mistakeReviewRate}}%</text>
        <text class="item-label">错题复习</text>
      </view>
    </view>
  </view>

  <!-- 科目统计 -->
  <view class="subject-stats-card card">
    <view class="card-title">📊 科目统计</view>
    <view class="subject-list">
      <view class="subject-item">
        <view class="subject-header">
          <text class="subject-name">📖 语文</text>
          <text class="subject-score {{subjectStats.chinese.avgScore >= 85 ? 'good' : 'normal'}}">{{subjectStats.chinese.avgScore}}分</text>
        </view>
        <view class="subject-bar">
          <view class="bar-fill chinese" style="width: {{subjectStats.chinese.avgScore}}%"></view>
        </view>
        <view class="subject-detail">
          <text>作业：{{subjectStats.chinese.homework}} | 错题：{{subjectStats.chinese.mistakes}}</text>
        </view>
      </view>
      
      <view class="subject-item">
        <view class="subject-header">
          <text class="subject-name">🔢 数学</text>
          <text class="subject-score {{subjectStats.math.avgScore >= 85 ? 'good' : 'normal'}}">{{subjectStats.math.avgScore}}分</text>
        </view>
        <view class="subject-bar">
          <view class="bar-fill math" style="width: {{subjectStats.math.avgScore}}%"></view>
        </view>
        <view class="subject-detail">
          <text>作业：{{subjectStats.math.homework}} | 错题：{{subjectStats.math.mistakes}}</text>
        </view>
      </view>
      
      <view class="subject-item">
        <view class="subject-header">
          <text class="subject-name">🔤 英语</text>
          <text class="subject-score {{subjectStats.english.avgScore >= 85 ? 'good' : 'normal'}}">{{subjectStats.english.avgScore}}分</text>
        </view>
        <view class="subject-bar">
          <view class="bar-fill english" style="width: {{subjectStats.english.avgScore}}%"></view>
        </view>
        <view class="subject-detail">
          <text>作业：{{subjectStats.english.homework}} | 错题：{{subjectStats.english.mistakes}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 错题分析 -->
  <view class="mistake-card card" wx:if="{{mistakeAnalysis.totalMistakes > 0}}">
    <view class="card-title">🎯 错题分析</view>
    
    <view class="mistake-summary">
      <view class="summary-item">
        <text class="summary-value">{{mistakeAnalysis.totalMistakes}}</text>
        <text class="summary-label">总错题</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">{{mistakeAnalysis.reviewedCount}}</text>
        <text class="summary-label">已复习</text>
      </view>
      <view class="summary-item">
        <text class="summary-value {{mistakeAnalysis.reviewRate >= 70 ? 'highlight' : ''}}">{{mistakeAnalysis.reviewRate}}%</text>
        <text class="summary-label">复习率</text>
      </view>
    </view>

    <view class="weak-points" wx:if="{{mistakeAnalysis.weakKnowledgePoints.length > 0}}">
      <view class="section-subtitle">💡 薄弱知识点 TOP5</view>
      <view class="point-list">
        <view class="point-item" wx:for="{{mistakeAnalysis.weakKnowledgePoints}}" wx:key="point" wx:for-index="index">
          <text class="point-rank">{{index + 1}}</text>
          <text class="point-name">{{item.point}}</text>
          <text class="point-count">{{item.count}}次</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 学习建议 -->
  <view class="suggestions-card card" wx:if="{{suggestions.length > 0}}">
    <view class="card-title">🌟 学习建议</view>
    <view class="suggestion-list">
      <view class="suggestion-item {{item.type}}" wx:for="{{suggestions}}" wx:key="title">
        <view class="suggestion-header">
          <text class="suggestion-icon">{{item.icon}}</text>
          <text class="suggestion-title">{{item.title}}</text>
          <view class="priority-tag {{item.priority}}">
            <text>{{item.priority === 'high' ? '重要' : (item.priority === 'medium' ? '一般' : '提醒')}}</text>
          </view>
        </view>
        <view class="suggestion-content">{{item.content}}</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && overview.totalHomework === 0}}">
    <text class="empty-icon">📊</text>
    <text class="empty-text">暂无学习数据</text>
    <text class="empty-hint">开始学习后就能看到报告啦～</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
