/* pages/report/report.wxss - 学习报告 */
.container {
  padding: 24rpx;
  background: #f5f7fa;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* 周期选择器 */
.period-selector {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
}

.period-item {
  flex: 1;
  padding: 16rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  font-weight: 600;
  transition: all 0.3s;
}

.period-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

/* 学习概览 */
.overview-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
}

.item-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.item-value.highlight {
  color: #667eea;
}

.item-label {
  font-size: 24rpx;
  color: #666;
}

/* 科目统计 */
.subject-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.subject-item {
  padding: 20rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
}

.subject-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.subject-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.subject-score {
  font-size: 28rpx;
  font-weight: bold;
}

.subject-score.good {
  color: #27ae60;
}

.subject-score.normal {
  color: #f39c12;
}

.subject-bar {
  height: 16rpx;
  background: #ddd;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.bar-fill.chinese {
  background: linear-gradient(90deg, #e74c3c 0%, #ff6b6b 100%);
}

.bar-fill.math {
  background: linear-gradient(90deg, #3498db 0%, #5dade2 100%);
}

.bar-fill.english {
  background: linear-gradient(90deg, #2ecc71 0%, #58d68d 100%);
}

.subject-detail {
  font-size: 24rpx;
  color: #666;
}

/* 错题分析 */
.mistake-summary {
  display: flex;
  justify-content: space-around;
  padding: 24rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.summary-value.highlight {
  color: #667eea;
}

.summary-label {
  font-size: 24rpx;
  color: #666;
}

.section-subtitle {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.point-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.point-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
}

.point-rank {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 16rpx;
}

.point-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.point-count {
  font-size: 26rpx;
  color: #666;
  font-weight: 600;
}

/* 学习建议 */
.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.suggestion-item {
  padding: 20rpx;
  border-radius: 12rpx;
  border-left: 4rpx solid;
}

.suggestion-item.strength {
  background: rgba(46, 204, 113, 0.1);
  border-left-color: #2ecc71;
}

.suggestion-item.improvement {
  background: rgba(243, 156, 18, 0.1);
  border-left-color: #f39c12;
}

.suggestion-item.encouragement {
  background: rgba(52, 152, 219, 0.1);
  border-left-color: #3498db;
}

.suggestion-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.suggestion-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.suggestion-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.priority-tag {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.priority-tag.high {
  background: #ffe8e8;
  color: #e74c3c;
}

.priority-tag.medium {
  background: #fff8e8;
  color: #f39c12;
}

.priority-tag.low {
  background: #e8f4ff;
  color: #3498db;
}

.suggestion-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  padding-left: 48rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}
