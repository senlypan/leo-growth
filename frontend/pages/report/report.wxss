/* pages/report/report.wxss - 学习报告（微信风格） */

.container {
  padding: 16rpx;
  background: #F5F5F5;
  min-height: 100vh;
}

.card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

/* 周期选择器 */
.period-selector {
  display: flex;
  gap: 12rpx;
  padding: 12rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.period-item {
  flex: 1;
  padding: 12rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666666;
  font-weight: 500;
}

.period-item.active {
  background: #07C160;
  color: #FFFFFF;
}

/* 学习概览 */
.overview-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
}

.item-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 8rpx;
}

.item-value.highlight {
  color: #07C160;
}

.item-label {
  font-size: 22rpx;
  color: #999999;
}

/* 科目统计 */
.subject-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.subject-item {
  padding: 20rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
}

.subject-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.subject-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
}

.subject-score {
  font-size: 26rpx;
  font-weight: 600;
}

.subject-score.good {
  color: #07C160;
}

.subject-score.normal {
  color: #FF9F00;
}

.subject-score.poor {
  color: #FA5151;
}

.subject-bar {
  height: 8rpx;
  background: #EEEEEE;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.bar-fill {
  height: 100%;
  border-radius: 4rpx;
}

.bar-fill.chinese {
  background: #FA5151;
}

.bar-fill.math {
  background: #10AEFF;
}

.bar-fill.english {
  background: #FF9F00;
}

.subject-detail {
  font-size: 24rpx;
  color: #999999;
}

/* 错题分析 */
.mistake-summary {
  display: flex;
  justify-content: space-around;
  padding: 20rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 8rpx;
}

.summary-value.highlight {
  color: #07C160;
}

.summary-label {
  font-size: 22rpx;
  color: #999999;
}

/* 知识点列表 */
.point-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.point-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
}

.point-rank {
  width: 40rpx;
  height: 40rpx;
  background: #07C160;
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  margin-right: 12rpx;
}

.point-name {
  flex: 1;
  font-size: 26rpx;
  color: #111111;
}

.point-count {
  font-size: 24rpx;
  color: #666666;
}

/* 学习建议 */
.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.suggestion-item {
  padding: 16rpx;
  border-radius: 8rpx;
  border-left: 4rpx solid;
}

.suggestion-item.strength {
  background: rgba(7, 193, 96, 0.08);
  border-left-color: #07C160;
}

.suggestion-item.improvement {
  background: rgba(255, 159, 0, 0.08);
  border-left-color: #FF9F00;
}

.suggestion-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.suggestion-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.suggestion-title {
  flex: 1;
  font-size: 26rpx;
  font-weight: 600;
  color: #111111;
}

.suggestion-content {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: #666666;
}

.empty-hint {
  font-size: 24rpx;
  color: #999999;
}
