<!--pages/index/index.wxml - 首页-->
<view class="container">
  <!-- 欢迎区域 -->
  <view class="welcome-card card">
    <view class="welcome-header">
      <text class="welcome-emoji">👋</text>
      <view class="welcome-text">
        <text class="welcome-title">你好，{{userInfo.nickname}}!</text>
        <text class="welcome-subtitle">今天也要加油哦～</text>
      </view>
    </view>
    
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-value">{{stats.homeworkCount}}</text>
        <text class="stat-label">今日作业</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{stats.mistakeCount}}</text>
        <text class="stat-label">错题数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{stats.continueDays}}</text>
        <text class="stat-label">连续打卡</text>
      </view>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="section-title">
    <text class="title-text">学习模块</text>
  </view>

  <view class="module-grid">
    <!-- 作业辅导员 -->
    <view class="module-card homework" bindtap="goToHomework">
      <view class="module-icon">📚</view>
      <text class="module-name">作业辅导</text>
      <text class="module-desc">智能辅导作业</text>
    </view>

    <!-- 学业规划师 -->
    <view class="module-card study" bindtap="goToStudy">
      <view class="module-icon">📖</view>
      <text class="module-name">学业规划</text>
      <text class="module-desc">学习路径规划</text>
    </view>

    <!-- 体能规划师 -->
    <view class="module-card fitness" bindtap="goToFitness">
      <view class="module-icon">🏃</view>
      <text class="module-name">体能训练</text>
      <text class="module-desc">科学运动计划</text>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="section-title">
    <text class="title-text">快捷功能</text>
  </view>

  <view class="quick-actions">
    <view class="quick-item" bindtap="goToMistakes">
      <view class="quick-icon">❌</view>
      <text class="quick-text">错题本</text>
    </view>
    <view class="quick-item" bindtap="goToReport">
      <view class="quick-icon">📊</view>
      <text class="quick-text">学习报告</text>
    </view>
    <view class="quick-item" bindtap="goToPlan">
      <view class="quick-icon">📅</view>
      <text class="quick-text">学习计划</text>
    </view>
    <view class="quick-item" bindtap="goToProfile">
      <view class="quick-icon">👤</view>
      <text class="quick-text">个人中心</text>
    </view>
  </view>
</view>
