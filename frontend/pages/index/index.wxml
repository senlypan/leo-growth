<!--pages/index/index.wxml - 首页（乔布斯设计版）-->
<view class="container">
  <!-- 欢迎区域 - 高端渐变 -->
  <view class="welcome-card premium-card">
    <view class="welcome-header">
      <text class="welcome-emoji-large">👋</text>
      <view class="welcome-text">
        <text class="welcome-title-gradient">你好，{{userInfo.nickname}}!</text>
        <text class="welcome-subtitle">今天也要加油哦～✨</text>
      </view>
    </view>
    
    <view class="stats-row-premium">
      <view class="stat-item-premium">
        <text class="stat-value-gradient">{{stats.homeworkCount}}</text>
        <text class="stat-label">📚 今日作业</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item-premium">
        <text class="stat-value-gradient">{{stats.mistakeCount}}</text>
        <text class="stat-label">❌ 错题数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item-premium">
        <text class="stat-value-gradient">{{stats.continueDays}}</text>
        <text class="stat-label">🔥 连续打卡</text>
      </view>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="section-title">
    <text class="title-text">🎯 学习模块</text>
  </view>

  <view class="module-grid-premium">
    <!-- 作业辅导员 -->
    <view class="module-card-premium homework" bindtap="goToHomework">
      <view class="module-icon-large">📚</view>
      <text class="module-name-premium">作业辅导</text>
      <text class="module-desc-premium">智能辅导作业</text>
      <view class="module-badge">✨</view>
    </view>

    <!-- 学业规划师 -->
    <view class="module-card-premium study" bindtap="goToStudy">
      <view class="module-icon-large">📖</view>
      <text class="module-name-premium">学业规划</text>
      <text class="module-desc-premium">学习路径规划</text>
      <view class="module-badge">🎯</view>
    </view>

    <!-- 体能规划师 -->
    <view class="module-card-premium fitness" bindtap="goToFitness">
      <view class="module-icon-large">🏃</view>
      <text class="module-name-premium">体能训练</text>
      <text class="module-desc-premium">科学运动计划</text>
      <view class="module-badge">💪</view>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="section-title">
    <text class="title-text">⚡ 快捷功能</text>
  </view>

  <view class="quick-actions-premium">
    <view class="quick-item-premium" bindtap="goToMistakes">
      <view class="quick-icon-large">❌</view>
      <text class="quick-text-premium">错题本</text>
    </view>
    <view class="quick-item-premium" bindtap="goToReport">
      <view class="quick-icon-large">📊</view>
      <text class="quick-text-premium">学习报告</text>
    </view>
    <view class="quick-item-premium" bindtap="goToPlan">
      <view class="quick-icon-large">📅</view>
      <text class="quick-text-premium">学习计划</text>
    </view>
    <view class="quick-item-premium" bindtap="goToProfile">
      <view class="quick-icon-large">👤</view>
      <text class="quick-text-premium">个人中心</text>
    </view>
  </view>
</view>
