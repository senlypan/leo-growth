<!--pages/index/index.wxml - 完整功能版-->
<view class="page">
  <!-- 欢迎卡片 -->
  <view class="welcome-card">
    <view class="welcome-header">
      <view class="welcome-text">
        <text class="welcome-title">你好，{{userInfo.nickname}}</text>
        <text class="welcome-subtitle">{{welcomeMessage}}</text>
      </view>
    </view>
    
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-value">{{stats.homeworkCount}}</text>
        <text class="stat-label">今日作业</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{stats.mistakeCount}}</text>
        <text class="stat-label">待复习</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{stats.continueDays}}</text>
        <text class="stat-label">连续打卡</text>
      </view>
    </view>
  </view>

  <!-- 学习模块 -->
  <view class="section-title">学习模块</view>
  
  <view class="module-grid">
    <view class="module-card" bindtap="goToHomework">
      <view class="module-icon homework-icon"></view>
      <text class="module-name">作业辅导</text>
      <text class="module-desc">拍照录入 · AI 识别 · 智能批改</text>
    </view>

    <view class="module-card" bindtap="goToMistakes">
      <view class="module-icon mistakes-icon"></view>
      <text class="module-name">错题本</text>
      <text class="module-desc">智能整理 · 艾宾浩斯复习</text>
    </view>

    <view class="module-card" bindtap="goToAssessment">
      <view class="module-icon assessment-icon"></view>
      <text class="module-name">能力评估</text>
      <text class="module-desc">全面测评 · 精准提升</text>
    </view>
  </view>

  <!-- 快捷功能 -->
  <view class="section-title">快捷功能</view>
  
  <view class="quick-grid">
    <view class="quick-item" bindtap="goToReport">
      <text class="quick-name">学习报告</text>
    </view>
    <view class="quick-item" bindtap="goToPlan">
      <text class="quick-name">学习计划</text>
    </view>
    <view class="quick-item" bindtap="goToGoals">
      <text class="quick-name">目标管理</text>
    </view>
    <view class="quick-item" bindtap="goToProfile">
      <text class="quick-name">个人中心</text>
    </view>
  </view>

  <!-- 学习建议 -->
  <view class="section-title">今日建议</view>
  
  <view class="suggestion-card">
    <view class="suggestion-item">
      <view class="suggestion-icon">📚</view>
      <view class="suggestion-content">
        <text class="suggestion-title">完成今日作业</text>
        <text class="suggestion-desc">还有 {{stats.homeworkCount}} 项作业待完成</text>
      </view>
      <view class="suggestion-action" bindtap="goToHomework">
        <text>去完成</text>
      </view>
    </view>
    <view class="suggestion-item">
      <view class="suggestion-icon">🔁</view>
      <view class="suggestion-content">
        <text class="suggestion-title">复习错题</text>
        <text class="suggestion-desc">{{stats.mistakeCount}} 道错题待复习</text>
      </view>
      <view class="suggestion-action" bindtap="goToMistakes">
        <text>去复习</text>
      </view>
    </view>
  </view>
</view>
