/* pages/index/index.wxss - 完整功能版 */

/* 欢迎卡片 */
.welcome-card {
  background: linear-gradient(135deg, #07C160 0%, #08B85F 100%);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
}

.welcome-header {
  margin-bottom: var(--space-4);
}

.welcome-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: var(--space-1);
  letter-spacing: -0.5rpx;
}

.welcome-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 统计数据 */
.stats-row {
  display: flex;
  justify-content: space-around;
  padding-top: var(--space-3);
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-1);
}

.stat-value {
  font-size: 44rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: -1rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  width: 1rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* 模块网格 */
.module-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-2);
  margin-bottom: var(--space-3);
}

.module-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
}

.module-card:active {
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-md);
}

.module-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-1);
}

.homework-icon {
  background: linear-gradient(135deg, #07C160 0%, #08B85F 100%);
}

.mistakes-icon {
  background: linear-gradient(135deg, #FF9F00 0%, #FF8800 100%);
}

.assessment-icon {
  background: linear-gradient(135deg, #10AEFF 0%, #0F9FEF 100%);
}

.module-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-1);
  letter-spacing: -0.3rpx;
}

.module-desc {
  font-size: 22rpx;
  color: var(--text-3);
  text-align: center;
  line-height: 1.4;
}

/* 快捷功能 */
.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-2);
  margin-bottom: var(--space-3);
}

.quick-item {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-sm);
}

.quick-item:active {
  background: var(--bg-3);
}

.quick-name {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-1);
}

/* 学习建议 */
.suggestion-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  box-shadow: var(--shadow-sm);
}

.suggestion-item {
  display: flex;
  align-items: center;
  padding: var(--space-3) 0;
  border-bottom: 1rpx solid var(--border-light);
}

.suggestion-item:last-child {
  border-bottom: none;
}

.suggestion-icon {
  font-size: 40rpx;
  margin-right: var(--space-2);
}

.suggestion-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.suggestion-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-1);
}

.suggestion-desc {
  font-size: 24rpx;
  color: var(--text-3);
}

.suggestion-action {
  padding: var(--space-1) var(--space-2);
  background: var(--primary);
  color: #FFFFFF;
  border-radius: var(--radius-md);
  font-size: 24rpx;
  font-weight: 500;
}

.suggestion-action:active {
  opacity: 0.7;
}

/* 章节标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-1);
  margin: var(--space-4) 0 var(--space-3);
  letter-spacing: -0.3rpx;
}
