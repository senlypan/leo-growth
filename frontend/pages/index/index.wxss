/* pages/index/index.wxss - 首页（乔布斯设计版） */

/* ===================================================
   欢迎卡片 - 高端渐变
   =================================================== */
.welcome-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 28rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.4);
  position: relative;
  overflow: hidden;
}

.welcome-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  animation: shimmer 3s infinite;
}

@keyframes shimmer {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(-20%, -20%); }
}

/* ===================================================
   欢迎头部
   =================================================== */
.welcome-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 40rpx;
  position: relative;
  z-index: 1;
}

.welcome-emoji-large {
  font-size: 80rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.2));
}

.welcome-text {
  flex: 1;
}

.welcome-title-gradient {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.welcome-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* ===================================================
   统计数据行 - 高端版
   =================================================== */
.stats-row-premium {
  display: flex;
  justify-content: space-around;
  align-items: center;
  position: relative;
  z-index: 1;
}

.stat-item-premium {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value-gradient {
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #fff 0%, #f0f0f0 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 2rpx;
}

/* ===================================================
   模块网格 - 高端版
   =================================================== */
.module-grid-premium {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.module-card-premium {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.module-card-premium:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.module-card-premium::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
}

.module-card-premium.homework::before {
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
}

.module-card-premium.study::before {
  background: linear-gradient(90deg, #f39c12 0%, #e67e22 100%);
}

.module-card-premium.fitness::before {
  background: linear-gradient(90deg, #2ecc71 0%, #27ae60 100%);
}

.module-icon-large {
  font-size: 64rpx;
  margin-bottom: 8rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.1));
}

.module-name-premium {
  font-size: 28rpx;
  font-weight: 700;
  color: #2c3e50;
}

.module-desc-premium {
  font-size: 22rpx;
  color: #95a5a6;
}

.module-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  font-size: 24rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.1));
}

/* ===================================================
   快捷操作 - 高端版
   =================================================== */
.quick-actions-premium {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.quick-item-premium {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.quick-item-premium:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.quick-icon-large {
  font-size: 48rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.1));
}

.quick-text-premium {
  font-size: 24rpx;
  font-weight: 600;
  color: #2c3e50;
}

/* ===================================================
   章节标题
   =================================================== */
.section-title {
  margin: 40rpx 0 24rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #2c3e50;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-text::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 4rpx;
}

/* ===================================================
   动画效果
   =================================================== */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.welcome-card {
  animation: fadeInUp 0.6s ease-out;
}

.module-grid-premium {
  animation: fadeInUp 0.6s ease-out 0.2s both;
}

.quick-actions-premium {
  animation: fadeInUp 0.6s ease-out 0.4s both;
}

/* ===================================================
   儿童友好细节
   =================================================== */
.module-card-premium,
.quick-item-premium {
  /* 大圆角 - 安全友好 */
  border-radius: 24rpx;
  
  /* 大间距 - 易点击 */
  padding: 32rpx 20rpx;
  
  /* 大图标 - 吸引注意 */
  .module-icon-large, .quick-icon-large {
    font-size: 64rpx;
  }
  
  /* 鲜艳色彩 - 吸引孩子 */
  &:hover {
    box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.2);
  }
}

/* ===================================================
   响应式设计
   =================================================== */
@media (max-width: 750rpx) {
  .stat-value-gradient {
    font-size: 40rpx;
  }
  
  .module-icon-large,
  .quick-icon-large {
    font-size: 56rpx;
  }
}
