/* pages/study/study.wxss - 学业规划首页 */
.container {
  padding: 24rpx;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

/* 欢迎卡片 */
.welcome-card {
  background: linear-gradient(135deg, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0.9) 100%);
}

.welcome-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.welcome-emoji {
  font-size: 64rpx;
}

.welcome-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.welcome-subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 模块卡片 */
.module-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s;
}

.module-card:active {
  transform: scale(0.98);
}

.module-card.disabled {
  opacity: 0.6;
}

.module-icon {
  font-size: 64rpx;
  min-width: 80rpx;
}

.module-info {
  flex: 1;
}

.module-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.module-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
}

.module-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 12rpx;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.module-arrow {
  font-size: 40rpx;
  color: #999;
}

.module-lock {
  font-size: 40rpx;
}

/* 不同模块的颜色 */
.module-card.assessment .module-icon {
  color: #667eea;
}

.module-card.path .module-icon {
  color: #f39c12;
}

.module-card.goals .module-icon {
  color: #2ecc71;
}

.module-card.report .module-icon {
  color: #3498db;
}

.module-card.plan .module-icon {
  color: #95a5a6;
}
