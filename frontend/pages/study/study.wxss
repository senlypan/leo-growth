/* pages/study/study.wxss - 学业规划（微信风格） */

.container {
  padding: 16rpx;
  background: #F5F5F5;
  min-height: 100vh;
}

.card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

/* 欢迎卡片 */
.welcome-card {
  background: linear-gradient(135deg, #07C160 0%, #09BB66 100%);
}

.welcome-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.welcome-emoji {
  font-size: 56rpx;
}

.welcome-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.welcome-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.5;
}

/* 模块卡片 */
.module-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.module-card:active {
  background: #FAFAFA;
}

.module-card.disabled {
  opacity: 0.5;
}

.module-icon {
  font-size: 56rpx;
  min-width: 72rpx;
  color: #07C160;
}

.module-info {
  flex: 1;
}

.module-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 8rpx;
}

.module-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.4;
}

.module-tag {
  display: inline-flex;
  padding: 6rpx 12rpx;
  background: rgba(7, 193, 96, 0.1);
  color: #07C160;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
  margin-top: 8rpx;
}

.module-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
}

.module-lock {
  font-size: 36rpx;
  color: #CCCCCC;
}
