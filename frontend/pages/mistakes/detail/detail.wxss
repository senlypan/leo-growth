/* pages/mistakes/detail/detail.wxss - 错题详情（微信风格） */

.container {
  padding: 16rpx;
  background: #F5F5F5;
  min-height: 100vh;
}

.card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

/* 题目卡片 */
.question-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.subject-badge {
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.subject-badge.chinese {
  background: rgba(250, 81, 81, 0.1);
  color: #FA5151;
}

.subject-badge.math {
  background: rgba(16, 174, 255, 0.1);
  color: #10AEFF;
}

.subject-badge.english {
  background: rgba(255, 159, 0, 0.1);
  color: #FF9F00;
}

.status-badge {
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-badge.reviewed {
  background: rgba(7, 193, 96, 0.1);
  color: #07C160;
}

.status-badge.unreviewed {
  background: rgba(255, 159, 0, 0.1);
  color: #FF9F00;
}

.question-content {
  margin-bottom: 24rpx;
}

.content-label {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.content-text {
  font-size: 28rpx;
  color: #111111;
  line-height: 1.6;
  background: #F5F5F5;
  padding: 16rpx;
  border-radius: 8rpx;
}

/* 答案区域 */
.answer-section {
  margin-bottom: 24rpx;
}

.answer-item {
  padding: 16rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
  border-left: 4rpx solid;
}

.answer-item.incorrect {
  background: rgba(250, 81, 81, 0.08);
  border-left-color: #FA5151;
}

.answer-item.correct {
  background: rgba(7, 193, 96, 0.08);
  border-left-color: #07C160;
}

.answer-label {
  font-size: 22rpx;
  color: #666666;
  margin-bottom: 8rpx;
  font-weight: 600;
}

.answer-text {
  font-size: 26rpx;
  color: #111111;
  line-height: 1.6;
}

/* 解析区域 */
.analysis-section {
  margin-bottom: 24rpx;
}

.analysis-content {
  padding: 16rpx;
  background: rgba(16, 174, 255, 0.05);
  border-radius: 8rpx;
  border-left: 4rpx solid #10AEFF;
}

.analysis-text {
  font-size: 26rpx;
  color: #111111;
  line-height: 1.6;
}

/* 知识点标签 */
.knowledge-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.knowledge-tag {
  padding: 6rpx 12rpx;
  background: #F5F5F5;
  border-radius: 6rpx;
  font-size: 22rpx;
  color: #666666;
}

/* 操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx;
  background: #FFFFFF;
  display: flex;
  gap: 12rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn:active {
  opacity: 0.8;
}

.btn-primary {
  background: #07C160;
  color: #FFFFFF;
}

.btn-secondary {
  background: #F5F5F5;
  color: #666666;
}
