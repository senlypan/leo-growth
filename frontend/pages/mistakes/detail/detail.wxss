/* pages/mistakes/detail/detail.wxss - 错题详情 */
.container {
  padding: 24rpx;
  background: #f5f7fa;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 题目卡片 */
.question-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.subject-badge {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.subject-badge.chinese {
  background: #ffe8e8;
  color: #e74c3c;
}

.subject-badge.math {
  background: #e8f4ff;
  color: #3498db;
}

.subject-badge.english {
  background: #fff8e8;
  color: #f39c12;
}

.status-badge {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.status-badge.reviewed {
  background: #e8ffe8;
  color: #27ae60;
}

.status-badge.unreviewed {
  background: #fff8e8;
  color: #f39c12;
}

.question-content {
  margin-bottom: 32rpx;
}

.content-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 600;
}

.content-text {
  font-size: 32rpx;
  color: #333;
  line-height: 1.8;
  background: #f5f7fa;
  padding: 24rpx;
  border-radius: 12rpx;
}

/* 答案区域 */
.answer-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.answer-item {
  padding: 24rpx;
  border-radius: 12rpx;
  border-left: 4rpx solid;
}

.answer-item.incorrect {
  background: #ffe8e8;
  border-left-color: #e74c3c;
}

.answer-item.correct {
  background: #e8ffe8;
  border-left-color: #27ae60;
}

.answer-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.answer-value {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

/* 分析卡片 */
.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.analysis-item {
  margin-bottom: 24rpx;
}

.analysis-item:last-child {
  margin-bottom: 0;
}

.item-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.item-value {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

.analysis-text {
  background: #f5f7fa;
  padding: 20rpx;
  border-radius: 8rpx;
}

/* 时间卡片 */
.time-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.time-item:last-child {
  border-bottom: none;
}

.time-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.time-label {
  font-size: 28rpx;
  color: #666;
  width: 160rpx;
}

.time-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
}

.action-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.review-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.delete-btn {
  background: #fff;
  color: #e74c3c;
  border: 2rpx solid #e74c3c;
}
