/* pages/mistakes/mistakes.wxss - 错题页（微信风格） */

.page-header {
  text-align: center;
  padding: 24rpx 0;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: #999999;
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #07C160 0%, #09BB66 100%);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-emoji {
  font-size: 28rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 筛选胶囊 */
.filter-capsules {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.capsule-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.capsule-row:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 24rpx;
  color: #666666;
  white-space: nowrap;
}

.capsule {
  padding: 8rpx 16rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #666666;
}

.capsule.active {
  background: #07C160;
  color: #FFFFFF;
}

/* 快捷功能 */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.quick-item {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 16rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.quick-item:active {
  background: #FAFAFA;
}

.quick-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #07C160;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-icon-emoji {
  font-size: 28rpx;
  color: #FFFFFF;
}

.quick-text {
  font-size: 22rpx;
  color: #666666;
}

/* 错题卡片 */
.mistake-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  position: relative;
  overflow: hidden;
}

.mistake-card:active {
  background: #FAFAFA;
}

.mistake-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 4rpx;
  height: 100%;
}

.mistake-card.chinese::before {
  background: #FA5151;
}

.mistake-card.math::before {
  background: #10AEFF;
}

.mistake-card.english::before {
  background: #FF9F00;
}

.mistake-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.subject-badge {
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.subject-badge.chinese {
  background: rgba(250, 81, 81, 0.1);
  color: #FA5151;
}

.subject-badge.math {
  background: rgba(16, 174, 255, 0.1);
  color: #10AEFF;
}

.subject-badge.english {
  background: rgba(255, 159, 0, 0.1);
  color: #FF9F00;
}

.status-badge {
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-badge.reviewed {
  background: rgba(7, 193, 96, 0.1);
  color: #07C160;
}

.status-badge.unreviewed {
  background: rgba(255, 159, 0, 0.1);
  color: #FF9F00;
}

.mistake-card-content {
  margin-bottom: 16rpx;
}

.content-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.label-emoji {
  font-size: 24rpx;
}

.label-text {
  font-size: 24rpx;
  color: #666666;
}

.mistake-card-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #111111;
  background: #F5F5F5;
  padding: 16rpx;
  border-radius: 8rpx;
}

/* 答案区域 */
.mistake-card-answer {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.answer-item {
  padding: 16rpx;
  border-radius: 8rpx;
  border-left: 4rpx solid;
}

.answer-item.incorrect {
  background: rgba(250, 81, 81, 0.08);
  border-left-color: #FA5151;
}

.answer-item.correct {
  background: rgba(7, 193, 96, 0.08);
  border-left-color: #07C160;
}

.answer-label {
  font-size: 22rpx;
  color: #666666;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.answer-value {
  font-size: 26rpx;
  color: #111111;
  font-weight: 500;
}

/* 卡片底部 */
.mistake-card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #EEEEEE;
}

.mistake-card-time {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.time-emoji {
  font-size: 24rpx;
}

.time-text {
  font-size: 22rpx;
  color: #999999;
}

.mistake-card-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 12rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
}

.tag-emoji {
  font-size: 20rpx;
}

.tag-text {
  font-size: 22rpx;
  color: #666666;
}

/* 空状态 */
.empty {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 64rpx 32rpx;
  text-align: center;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.4;
}

.empty-title {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #999999;
}
