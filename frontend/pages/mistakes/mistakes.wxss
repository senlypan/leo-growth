/* pages/mistakes/mistakes.wxss - 错题本样式 */

/* 统计卡片 */
.stats-card {
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-muted);
}

.stat-divider {
  width: 2rpx;
  height: 70rpx;
  background: var(--border-color);
}

/* 筛选栏 */
.filter-bar {
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.filter-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.filter-row:last-child {
  margin-bottom: 0;
}

.filter-item {
  flex: 1;
  padding: 12rpx 20rpx;
  background: var(--bg-color);
  border-radius: 20rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.filter-item text {
  font-size: 24rpx;
  color: var(--text-light);
}

.filter-item.active {
  background: var(--primary-color);
  border-color: var(--primary-color);
}

.filter-item.active text {
  color: var(--white);
}

/* 快捷功能 */
.quick-actions {
  padding: 20rpx;
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.quick-icon {
  font-size: 40rpx;
}

.quick-text {
  font-size: 22rpx;
  color: var(--text-light);
}

/* 错题列表 */
.mistake-list {
  margin-bottom: 40rpx;
}

.mistake-card {
  padding: 24rpx;
  margin-bottom: 20rpx;
  transition: all 0.2s;
}

.mistake-card:active {
  transform: scale(0.98);
}

.mistake-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.subject-badge {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.subject-badge.chinese {
  background: rgba(231, 76, 60, 0.15);
  color: #e74c3c;
}

.subject-badge.math {
  background: rgba(52, 152, 219, 0.15);
  color: #3498db;
}

.subject-badge.english {
  background: rgba(46, 204, 113, 0.15);
  color: #2ecc71;
}

.status-badge {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
}

.status-badge.reviewed {
  background: rgba(46, 204, 113, 0.15);
  color: #2ecc71;
}

.status-badge.unreviewed {
  background: rgba(243, 156, 18, 0.15);
  color: #f39c12;
}

.mistake-content {
  margin-bottom: 20rpx;
}

.content-label {
  font-size: 24rpx;
  color: var(--text-muted);
  display: block;
  margin-bottom: 8rpx;
}

.content-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-color);
}

.mistake-analysis {
  padding: 16rpx;
  background: var(--bg-color);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.analysis-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.analysis-item:last-child {
  margin-bottom: 0;
}

.analysis-label {
  font-size: 24rpx;
  color: var(--text-light);
  flex-shrink: 0;
}

.analysis-value {
  font-size: 26rpx;
  font-weight: bold;
}

.analysis-value.incorrect {
  color: #e74c3c;
}

.analysis-value.correct {
  color: #2ecc71;
}

.mistake-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 2rpx solid var(--border-color);
}

.mistake-time {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.time-icon {
  font-size: 24rpx;
}

.time-text {
  font-size: 22rpx;
  color: var(--text-muted);
}

.mistake-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  background: rgba(52, 152, 219, 0.1);
  border-radius: 16rpx;
}

.tag-icon {
  font-size: 20rpx;
}

.tag-text {
  font-size: 22rpx;
  color: #3498db;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-color);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-muted);
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  padding: 40rpx;
  color: var(--text-muted);
  font-size: 26rpx;
}
