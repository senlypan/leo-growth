/* pages/mistakes/submit/submit.wxss - 录入错题（微信风格） */

.container {
  padding: 16rpx;
  background: #F5F5F5;
  min-height: 100vh;
}

.form-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.form-section {
  margin-bottom: 32rpx;
}

.form-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 16rpx;
}

/* 科目选择器 */
.subject-selector {
  display: flex;
  gap: 12rpx;
}

.subject-option {
  flex: 1;
  padding: 16rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666666;
}

.subject-option:active {
  opacity: 0.7;
}

.subject-option.active {
  background: #07C160;
  color: #FFFFFF;
  font-weight: 600;
}

/* 输入框 */
.input-area {
  width: 100%;
  min-height: 160rpx;
  padding: 16rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.6;
  border: 1rpx solid #EEEEEE;
}

.input-field {
  width: 100%;
  padding: 16rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: 1rpx solid #EEEEEE;
}

/* 错误类型选择器 */
.error-type-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.error-type-option {
  padding: 12rpx 20rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666666;
  border: 2rpx solid transparent;
}

.error-type-option:active {
  opacity: 0.7;
}

.error-type-option.active {
  border-color: #07C160;
  background: rgba(7, 193, 96, 0.08);
  color: #07C160;
}

/* 知识点输入 */
.knowledge-input {
  width: 100%;
  padding: 16rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: 1rpx solid #EEEEEE;
}

/* 提示区域 */
.tips-section {
  padding: 16rpx;
  background: rgba(255, 159, 0, 0.08);
  border-radius: 8rpx;
  border-left: 4rpx solid #FF9F00;
  margin-bottom: 24rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 88rpx;
  background: #07C160;
  color: #FFFFFF;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.submit-btn:active {
  opacity: 0.8;
}

.submit-btn.disabled {
  background: #CCCCCC;
}
