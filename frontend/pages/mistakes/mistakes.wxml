<!--pages/mistakes/mistakes.wxml - 错题本-->
<view class="container">
  <!-- 统计卡片 -->
  <view class="stats-card card">
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-value">{{stats.total}}</text>
        <text class="stat-label">总题数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{stats.unreviewed}}</text>
        <text class="stat-label">待复习</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{stats.reviewed}}</text>
        <text class="stat-label">已掌握</text>
      </view>
    </view>
  </view>

  <!-- 筛选栏 -->
  <view class="filter-bar card">
    <view class="filter-row">
      <view class="filter-item {{currentSubject === 'all' ? 'active' : ''}}" 
            bindtap="selectSubject" 
            data-subject="all">
        <text>全部</text>
      </view>
      <view class="filter-item {{currentSubject === 'chinese' ? 'active' : ''}}" 
            bindtap="selectSubject" 
            data-subject="chinese">
        <text>📖 语文</text>
      </view>
      <view class="filter-item {{currentSubject === 'math' ? 'active' : ''}}" 
            bindtap="selectSubject" 
            data-subject="math">
        <text>🔢 数学</text>
      </view>
      <view class="filter-item {{currentSubject === 'english' ? 'active' : ''}}" 
            bindtap="selectSubject" 
            data-subject="english">
        <text>🔤 英语</text>
      </view>
    </view>
    
    <view class="filter-row">
      <view class="filter-item {{currentStatus === 'all' ? 'active' : ''}}" 
            bindtap="selectStatus" 
            data-status="all">
        <text>全部</text>
      </view>
      <view class="filter-item {{currentStatus === 'unreviewed' ? 'active' : ''}}" 
            bindtap="selectStatus" 
            data-status="unreviewed">
        <text>⏳ 待复习</text>
      </view>
      <view class="filter-item {{currentStatus === 'reviewed' ? 'active' : ''}}" 
            bindtap="selectStatus" 
            data-status="reviewed">
        <text>✅ 已掌握</text>
      </view>
    </view>
  </view>

  <!-- 快捷功能 -->
  <view class="quick-actions card">
    <view class="quick-item" bindtap="addMistake">
      <text class="quick-icon">➕</text>
      <text class="quick-text">录入错题</text>
    </view>
    <view class="quick-item" bindtap="exportMistakes">
      <text class="quick-icon">📤</text>
      <text class="quick-text">导出错题</text>
    </view>
    <view class="quick-item" bindtap="mistakePractice">
      <text class="quick-icon">📝</text>
      <text class="quick-text">错题练习</text>
    </view>
    <view class="quick-item" bindtap="mistakeAnalysis">
      <text class="quick-icon">📊</text>
      <text class="quick-text">错题分析</text>
    </view>
  </view>

  <!-- 错题列表 -->
  <view class="mistake-list">
    <!-- 空状态 -->
    <view class="empty" wx:if="{{mistakeList.length === 0}}">
      <text class="empty-icon">🎯</text>
      <text class="empty-text">暂无错题</text>
      <text class="empty-hint">太棒了！继续保持～</text>
    </view>

    <!-- 错题卡片 -->
    <view class="mistake-card card" 
          wx:for="{{mistakeList}}" 
          wx:key="id"
          bindtap="goToDetail"
          data-id="{{item.id}}">
      
      <view class="mistake-header">
        <view class="subject-badge {{item.subject}}">
          <text>{{subjectNames[item.subject]}}</text>
        </view>
        <view class="status-badge {{item.reviewed ? 'reviewed' : 'unreviewed'}}">
          <text>{{item.reviewed ? '✅ 已掌握' : '⏳ 待复习'}}</text>
        </view>
      </view>

      <view class="mistake-content">
        <text class="content-label">题目：</text>
        <text class="content-text">{{item.question}}</text>
      </view>

      <view class="mistake-analysis" wx:if="{{item.userAnswer}}">
        <view class="analysis-item">
          <text class="analysis-label">你的答案：</text>
          <text class="analysis-value incorrect">{{item.userAnswer}}</text>
        </view>
        <view class="analysis-item">
          <text class="analysis-label">正确答案：</text>
          <text class="analysis-value correct">{{item.correctAnswer}}</text>
        </view>
      </view>

      <view class="mistake-footer">
        <view class="mistake-time">
          <text class="time-icon">📅</text>
          <text class="time-text">{{item.createTime}}</text>
        </view>
        <view class="mistake-tag" wx:if="{{item.knowledgePoint}}">
          <text class="tag-icon">📌</text>
          <text class="tag-text">{{item.knowledgePoint}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
