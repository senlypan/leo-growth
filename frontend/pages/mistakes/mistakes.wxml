<!--pages/mistakes/mistakes.wxml - 真实数据版-->
<view class="page">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">错题本</text>
    <text class="page-subtitle">温故而知新</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{isLoading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:elif="{{isEmpty}}">
    <view class="empty-icon">📝</view>
    <text class="empty-title">还没有错题</text>
    <text class="empty-desc">开始录入第一道错题吧</text>
    <view class="empty-actions">
      <view class="btn-primary" bindtap="addMistake">录入错题</view>
    </view>
  </view>

  <!-- 错题列表 -->
  <view wx:else>
    <!-- 统计卡片 -->
    <view class="stats-card">
      <view class="stat-item">
        <text class="stat-value">{{stats.total}}</text>
        <text class="stat-label">总题数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{stats.unreviewed}}</text>
        <text class="stat-label">待复习</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{stats.reviewed}}</text>
        <text class="stat-label">已掌握</text>
      </view>
    </view>

    <!-- 筛选栏 -->
    <view class="filter-bar">
      <view class="filter-item {{currentSubject === 'all' ? 'active' : ''}}" bindtap="selectSubject" data-subject="all">全部</view>
      <view class="filter-item {{currentSubject === 'chinese' ? 'active' : ''}}" bindtap="selectSubject" data-subject="chinese">语文</view>
      <view class="filter-item {{currentSubject === 'math' ? 'active' : ''}}" bindtap="selectSubject" data-subject="math">数学</view>
      <view class="filter-item {{currentSubject === 'english' ? 'active' : ''}}" bindtap="selectSubject" data-subject="english">英语</view>
    </view>

    <view class="filter-bar">
      <view class="filter-item {{currentStatus === 'all' ? 'active' : ''}}" bindtap="selectStatus" data-status="all">全部</view>
      <view class="filter-item {{currentStatus === 'unreviewed' ? 'active' : ''}}" bindtap="selectStatus" data-status="unreviewed">待复习</view>
      <view class="filter-item {{currentStatus === 'reviewed' ? 'active' : ''}}" bindtap="selectStatus" data-status="reviewed">已掌握</view>
    </view>

    <!-- 快捷功能 -->
    <view class="quick-actions">
      <view class="quick-item" bindtap="addMistake">
        <view class="quick-icon">➕</view>
        <text class="quick-text">录入错题</text>
      </view>
      <view class="quick-item" bindtap="reviewMistake">
        <view class="quick-icon">🔁</view>
        <text class="quick-text">智能复习</text>
      </view>
      <view class="quick-item" bindtap="exportMistakes">
        <view class="quick-icon">📤</view>
        <text class="quick-text">导出错题</text>
      </view>
      <view class="quick-item" bindtap="mistakeStats">
        <view class="quick-icon">📈</view>
        <text class="quick-text">统计分析</text>
      </view>
    </view>

    <!-- 错题列表 -->
    <view class="mistake-list" wx:if="{{filteredList.length > 0}}">
      <view class="mistake-card {{item.subject}}" wx:for="{{filteredList}}" wx:key="id">
        <view class="mistake-card-header">
          <view class="subject-badge {{item.subject}}">{{item.subjectName}}</view>
          <view class="status-badge {{item.status}}">{{item.statusText}}</view>
        </view>
        <view class="mistake-card-content">
          <view class="content-label">
            <text class="label-emoji">📝</text>
            <text class="label-text">题目</text>
          </view>
          <text class="mistake-card-text">{{item.question}}</text>
        </view>
        <view class="mistake-card-answer" wx:if="{{item.userAnswer}}">
          <view class="answer-item incorrect">
            <text class="answer-label">你的答案</text>
            <text class="answer-value">{{item.userAnswer}}</text>
          </view>
          <view class="answer-item correct">
            <text class="answer-label">正确答案</text>
            <text class="answer-value">{{item.correctAnswer}}</text>
          </view>
        </view>
        <view class="mistake-card-footer">
          <view class="mistake-card-time">
            <text class="time-text">{{item.createTime}}</text>
          </view>
          <view class="mistake-card-actions">
            <view class="action-btn review-btn" bindtap="viewDetail" data-id="{{item.id}}">查看</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空结果 -->
    <view class="empty-result" wx:if="{{filteredList.length === 0}}">
      <text class="empty-result-text">没有符合条件的错题</text>
    </view>
  </view>
</view>
