/* ===================================================
   Leo Growth - 全局样式（高级极简版）
   设计理念：少即是多 · 克制 · 精致 · 留白
   =================================================== */

/* ===================================================
   设计令牌
   =================================================== */
page {
  /* 主色 - 单一克制 */
  --primary: #07C160;
  --primary-light: #08B85F;
  --primary-dark: #06A555;
  
  /* 中性色 - 精致层次 */
  --text-1: #1A1A1A;
  --text-2: #666666;
  --text-3: #999999;
  --text-4: #CCCCCC;
  
  /* 背景色 - 干净纯粹 */
  --bg-1: #F7F8FA;
  --bg-2: #FFFFFF;
  --bg-3: #F0F2F5;
  
  /* 边框 - 精致细腻 */
  --border: #E8EAED;
  --border-light: #F0F2F5;
  
  /* 圆角 - 适度精致 */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  
  /* 间距 - 严格 8 倍数 */
  --space-1: 8rpx;
  --space-2: 16rpx;
  --space-3: 24rpx;
  --space-4: 32rpx;
  --space-5: 48rpx;
  
  /* 阴影 - 极其克制 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* ===================================================
   基础样式
   =================================================== */
page {
  background-color: var(--bg-1);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--text-1);
  -webkit-font-smoothing: antialiased;
}

/* ===================================================
   页面容器 - 大量留白
   =================================================== */
.page {
  min-height: 100vh;
  background-color: var(--bg-1);
  padding: var(--space-3);
}

/* ===================================================
   卡片 - 极简克制
   =================================================== */
.card {
  background-color: var(--bg-2);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-2);
  box-shadow: var(--shadow-sm);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: var(--space-2);
  margin-bottom: var(--space-2);
  border-bottom: 1rpx solid var(--border-light);
}

/* ===================================================
   按钮 - 扁平精致
   =================================================== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-2) var(--space-3);
  border-radius: var(--radius-md);
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  transition: all 0.2s ease;
}

.btn:active {
  opacity: 0.7;
  transform: scale(0.98);
}

.btn-primary {
  background-color: var(--primary);
  color: #FFFFFF;
}

.btn-secondary {
  background-color: var(--bg-3);
  color: var(--text-1);
}

.btn-ghost {
  background-color: transparent;
  color: var(--primary);
}

/* ===================================================
   标题层级 - 清晰精致
   =================================================== */
.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-1);
  letter-spacing: -0.5rpx;
  margin-bottom: var(--space-1);
}

.page-subtitle {
  font-size: 26rpx;
  color: var(--text-3);
  font-weight: 400;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-1);
  margin: var(--space-5) 0 var(--space-3);
  letter-spacing: -0.3rpx;
}

/* ===================================================
   文字层级
   =================================================== */
.text-1 { color: var(--text-1); }
.text-2 { color: var(--text-2); }
.text-3 { color: var(--text-3); }
.text-primary { color: var(--primary); }

.text-bold { font-weight: 600; }
.text-center { text-align: center; }
.text-sm { font-size: 24rpx; }

/* ===================================================
   徽章 - 极简
   =================================================== */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-weight: 500;
  background-color: rgba(7, 193, 96, 0.08);
  color: var(--primary);
}

/* ===================================================
   列表 - 微信风格
   =================================================== */
.list {
  background-color: var(--bg-2);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.list-item {
  display: flex;
  align-items: center;
  padding: var(--space-3);
  border-bottom: 1rpx solid var(--border-light);
}

.list-item:last-child {
  border-bottom: none;
}

.list-item:active {
  background-color: var(--bg-3);
}

/* ===================================================
   分割线
   =================================================== */
.divider {
  height: 1rpx;
  background-color: var(--border);
  margin: var(--space-2) 0;
}

/* ===================================================
   空状态 - 极简留白
   =================================================== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-6) var(--space-4);
  text-align: center;
}

.empty-title {
  font-size: 30rpx;
  color: var(--text-2);
  margin-bottom: var(--space-1);
  font-weight: 500;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-3);
  line-height: 1.6;
}

/* ===================================================
   布局工具
   =================================================== */
.flex { display: flex; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-column { display: flex; flex-direction: column; }
.flex-1 { flex: 1; }
.gap-1 { gap: var(--space-1); }
.gap-2 { gap: var(--space-2); }
.gap-3 { gap: var(--space-3); }

.grid { display: grid; gap: var(--space-2); }
.grid-2 { grid-template-columns: repeat(2, 1fr); }
.grid-3 { grid-template-columns: repeat(3, 1fr); }

/* ===================================================
   间距工具
   =================================================== */
.mt-1 { margin-top: var(--space-1); }
.mt-2 { margin-top: var(--space-2); }
.mt-3 { margin-top: var(--space-3); }
.mt-4 { margin-top: var(--space-4); }
.mb-1 { margin-bottom: var(--space-1); }
.mb-2 { margin-bottom: var(--space-2); }
.mb-3 { margin-bottom: var(--space-3); }
.mb-4 { margin-bottom: var(--space-4); }

/* ===================================================
   输入框
   =================================================== */
.input {
  width: 100%;
  padding: var(--space-2);
  font-size: 30rpx;
  background-color: var(--bg-3);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
}

/* ===================================================
   进度条
   =================================================== */
.progress {
  height: 6rpx;
  background-color: var(--border);
  border-radius: 3rpx;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background-color: var(--primary);
  border-radius: 3rpx;
  transition: width 0.3s ease;
}

/* ===================================================
   动画 - 极其克制
   =================================================== */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.fade-in {
  animation: fadeIn 0.2s ease;
}

/* ===================================================
   导航栏
   =================================================== */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 var(--space-3);
  background-color: var(--bg-2);
  border-bottom: 1rpx solid var(--border-light);
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-bar-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-1);
  letter-spacing: -0.3rpx;
}
