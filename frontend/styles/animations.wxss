/* ===================================================
   Leo Growth - 游戏化动画系统
   乔布斯设计版 v3.0
   =================================================== */

/* ===================================================
   1. 呼吸渐变背景
   =================================================== */
@keyframes breathingGradient {
  0%, 100% { 
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  }
  50% { 
    background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
  }
}

.premium-card {
  animation: breathingGradient 3s ease-in-out infinite;
}

/* ===================================================
   2. 流光溢彩效果
   =================================================== */
@keyframes shimmer {
  0% {
    transform: translateX(-100%) rotate(45deg);
  }
  100% {
    transform: translateX(500%) rotate(45deg);
  }
}

.shimmer-effect {
  position: relative;
  overflow: hidden;
}

.shimmer-effect::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent 30%,
    rgba(255, 255, 255, 0.3) 50%,
    transparent 70%
  );
  animation: shimmer 2s infinite;
}

/* ===================================================
   3. 3D 悬浮效果
   =================================================== */
@keyframes float3D {
  0%, 100% {
    transform: perspective(1000px) rotateX(0deg) translateY(0);
  }
  50% {
    transform: perspective(1000px) rotateX(5deg) translateY(-10rpx);
  }
}

.float-3d {
  animation: float3D 3s ease-in-out infinite;
  transform-style: preserve-3d;
}

/* ===================================================
   4. 按钮按压效果
   =================================================== */
@keyframes buttonPress {
  0% {
    transform: perspective(1000px) translateZ(0);
  }
  50% {
    transform: perspective(1000px) translateZ(-10rpx);
  }
  100% {
    transform: perspective(1000px) translateZ(0);
  }
}

.btn-3d:active {
  animation: buttonPress 0.2s ease-out;
}

/* ===================================================
   5. 彩带庆祝动画
   =================================================== */
@keyframes confetti {
  0% {
    transform: translateY(-100vh) rotate(0deg);
    opacity: 1;
  }
  100% {
    transform: translateY(100vh) rotate(720deg);
    opacity: 0;
  }
}

.confetti {
  position: fixed;
  width: 20rpx;
  height: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  animation: confetti 3s ease-out forwards;
}

.confetti:nth-child(odd) {
  background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
}

.confetti:nth-child(3n) {
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
}

/* ===================================================
   6. 星星闪烁动画
   =================================================== */
@keyframes starTwinkle {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.5;
    transform: scale(1.2);
  }
}

.star {
  animation: starTwinkle 1.5s ease-in-out infinite;
}

.star:nth-child(2n) {
  animation-delay: 0.5s;
}

.star:nth-child(3n) {
  animation-delay: 1s;
}

/* ===================================================
   7. 弹跳动画
   =================================================== */
@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-20rpx);
  }
}

.bounce {
  animation: bounce 1s ease-in-out infinite;
}

/* ===================================================
   8. 脉冲光晕
   =================================================== */
@keyframes pulse {
  0%, 100% {
    box-shadow: 0 0 40rpx rgba(102, 126, 234, 0.3);
  }
  50% {
    box-shadow: 0 0 80rpx rgba(102, 126, 234, 0.6);
  }
}

.pulse-glow {
  animation: pulse 2s ease-in-out infinite;
}

/* ===================================================
   9. 旋转入场
   =================================================== */
@keyframes rotateIn {
  0% {
    transform: rotate(-180deg) scale(0);
    opacity: 0;
  }
  100% {
    transform: rotate(0) scale(1);
    opacity: 1;
  }
}

.rotate-in {
  animation: rotateIn 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

/* ===================================================
   10. 缩放淡入
   =================================================== */
@keyframes zoomFadeIn {
  0% {
    transform: scale(0.8);
    opacity: 0;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.zoom-fade-in {
  animation: zoomFadeIn 0.4s ease-out;
}

/* ===================================================
   11. 滑动入场
   =================================================== */
@keyframes slideInLeft {
  0% {
    transform: translateX(-100%);
    opacity: 0;
  }
  100% {
    transform: translateX(0);
    opacity: 1;
  }
}

@keyframes slideInRight {
  0% {
    transform: translateX(100%);
    opacity: 0;
  }
  100% {
    transform: translateX(0);
    opacity: 1;
  }
}

.slide-in-left {
  animation: slideInLeft 0.5s ease-out;
}

.slide-in-right {
  animation: slideInRight 0.5s ease-out;
}

/* ===================================================
   12. 进度条动画
   =================================================== */
@keyframes progress {
  0% {
    width: 0;
  }
  100% {
    width: 100%;
  }
}

.progress-bar {
  animation: progress 1s ease-out;
}

/* ===================================================
   13. 加载旋转
   =================================================== */
@keyframes spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

.spinner {
  animation: spin 1s linear infinite;
}

/* ===================================================
   14. 心跳动画
   =================================================== */
@keyframes heartbeat {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.1);
  }
}

.heartbeat {
  animation: heartbeat 1s ease-in-out infinite;
}

/* ===================================================
   15. 摇晃动画
   =================================================== */
@keyframes shake {
  0%, 100% {
    transform: translateX(0);
  }
  25% {
    transform: translateX(-10rpx);
  }
  75% {
    transform: translateX(10rpx);
  }
}

.shake {
  animation: shake 0.5s ease-in-out;
}

/* ===================================================
   16. 爆炸效果
   =================================================== */
@keyframes explode {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  100% {
    transform: scale(2);
    opacity: 0;
  }
}

.explode {
  animation: explode 0.5s ease-out forwards;
}

/* ===================================================
   17. 水滴涟漪
   =================================================== */
@keyframes ripple {
  0% {
    transform: scale(0);
    opacity: 1;
  }
  100% {
    transform: scale(4);
    opacity: 0;
  }
}

.ripple {
  animation: ripple 1s ease-out forwards;
}

/* ===================================================
   18. 渐变文字
   =================================================== */
@keyframes gradientText {
  0% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0% 50%;
  }
}

.gradient-text {
  background: linear-gradient(
    270deg,
    #667eea,
    #764ba2,
    #f39c12,
    #2ecc71,
    #667eea
  );
  background-size: 400% 400%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: gradientText 3s ease infinite;
}

/* ===================================================
   19. 儿童友好动画类
   =================================================== */

/* 大按钮点击反馈 */
.btn-kid:active {
  transform: scale(0.9);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

/* 卡片悬浮 */
.card-kid:hover {
  transform: translateY(-8rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}

/* emoji 弹跳 */
.emoji-bounce {
  display: inline-block;
  animation: bounce 1s ease-in-out infinite;
}

/* 数字滚动 */
.number-roll {
  display: inline-block;
  animation: zoomFadeIn 0.3s ease-out;
}

/* 徽章获得 */
.badge-earn {
  animation: rotateIn 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55),
             pulse 2s ease-in-out infinite 0.6s;
}

/* 等级提升 */
.level-up {
  animation: zoomFadeIn 0.5s ease-out,
             pulse 1s ease-in-out infinite 0.5s;
}

/* 任务完成 */
.task-complete {
  animation: slideInLeft 0.4s ease-out;
}

/* 成就解锁 */
.achievement-unlock {
  animation: rotateIn 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55),
             starTwinkle 1.5s ease-in-out infinite 0.8s;
}

/* ===================================================
   20. 场景动画
   =================================================== */

/* 清晨场景 */
.morning-scene {
  background: linear-gradient(180deg, #ffecd2 0%, #fcb69f 100%);
}

/* 白天场景 */
.day-scene {
  background: linear-gradient(180deg, #a1c4fd 0%, #c2e9fb 100%);
}

/* 夜晚场景 */
.night-scene {
  background: linear-gradient(180deg, #0f2027 0%, #203a43 50%, #2c5364 100%);
}

/* 庆祝场景 */
.celebration-scene {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  animation: pulse 2s ease-in-out infinite;
}

/* ===================================================
   工具类
   =================================================== */

/* 延迟 */
.delay-100 { animation-delay: 0.1s; }
.delay-200 { animation-delay: 0.2s; }
.delay-300 { animation-delay: 0.3s; }
.delay-500 { animation-delay: 0.5s; }
.delay-1000 { animation-delay: 1s; }

/* 持续时间 */
.duration-fast { animation-duration: 0.2s; }
.duration-normal { animation-duration: 0.4s; }
.duration-slow { animation-duration: 0.6s; }
.duration-slower { animation-duration: 1s; }

/* 循环 */
.loop-infinite { animation-iteration-count: infinite; }
.loop-3 { animation-iteration-count: 3; }

/* 填充模式 */
.fill-forwards { animation-fill-mode: forwards; }
.fill-backwards { animation-fill-mode: backwards; }
.fill-both { animation-fill-mode: both; }
