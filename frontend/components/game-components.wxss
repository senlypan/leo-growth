/* ===================================================
   Leo Growth - 游戏化组件样式
   乔布斯设计版 v3.0
   =================================================== */

/* ===================================================
   1. 庆祝动画组件样式
   =================================================== */
.confetti {
  position: fixed;
  width: 20rpx;
  height: 20rpx;
  top: -20rpx;
  z-index: 9999;
}

.star {
  position: fixed;
  z-index: 9998;
  animation: starTwinkle 1.5s ease-in-out infinite;
}

.level-up {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 10000;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 80rpx;
  border-radius: 36rpx;
  box-shadow: 0 20rpx 60rpx rgba(102, 126, 234, 0.5);
  animation: zoomFadeIn 0.5s ease-out, pulse 1s ease-in-out infinite 0.5s;
}

.level-up-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.level-up-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.level-up-from,
.level-up-to {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.level-up-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ===================================================
   2. 进度条组件样式
   =================================================== */
.progress-bar-container {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar-bg {
  flex: 1;
  height: 24rpx;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 12rpx;
  position: relative;
  overflow: hidden;
  transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

.progress-bar-shimmer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.3),
    transparent
  );
  animation: shimmer 2s infinite;
}

.progress-bar-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #7f8c8d;
  min-width: 80rpx;
  text-align: right;
}

/* ===================================================
   3. 徽章组件样式
   =================================================== */
.badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.badge:active {
  transform: scale(0.95);
}

.badge-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.badge-emoji {
  font-size: 48rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.2));
}

.badge-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2c3e50;
  margin-bottom: 4rpx;
}

.badge-description {
  font-size: 22rpx;
  color: #95a5a6;
  text-align: center;
}

.badge-locked {
  font-size: 20rpx;
  color: #95a5a6;
  margin-top: 8rpx;
}

.badge.earned {
  animation: badgeEarn 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

@keyframes badgeEarn {
  0% {
    transform: rotate(-180deg) scale(0);
    opacity: 0;
  }
  100% {
    transform: rotate(0) scale(1);
    opacity: 1;
  }
}

/* ===================================================
   4. 卡片组件样式
   =================================================== */
.card {
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.card-premium {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.4);
}

.card-gradient {
  background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(243, 156, 18, 0.4);
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.card-content {
  display: block;
  font-size: 28rpx;
  line-height: 1.8;
  color: #7f8c8d;
}

.card-premium .card-content {
  color: rgba(255, 255, 255, 0.9);
}

.card-footer {
  display: block;
  font-size: 24rpx;
  color: #95a5a6;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid rgba(0, 0, 0, 0.05);
}

.card-premium .card-footer {
  border-top-color: rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.8);
}

/* ===================================================
   5. 按钮组件样式
   =================================================== */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 40rpx;
  border-radius: 36rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn:active {
  transform: scale(0.95);
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.btn-success {
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(46, 204, 113, 0.3);
}

.btn-warning {
  background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(243, 156, 18, 0.3);
}

.btn-danger {
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(231, 76, 60, 0.3);
}

.btn-secondary {
  background: #f8f9fa;
  color: #667eea;
  border: 2rpx solid #667eea;
}

.btn-small {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
}

.btn-large {
  padding: 28rpx 56rpx;
  font-size: 34rpx;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-loading {
  animation: spin 1s linear infinite;
}

.btn.disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* ===================================================
   6. 提示组件样式
   =================================================== */
.toast {
  position: fixed;
  top: 100rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #fff;
  padding: 24rpx 40rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  display: flex;
  align-items: center;
  gap: 16rpx;
  z-index: 10000;
  animation: slideInTop 0.3s ease-out;
  transition: opacity 0.3s ease-out;
}

@keyframes slideInTop {
  from {
    transform: translateX(-50%) translateY(-100rpx);
    opacity: 0;
  }
  to {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
  }
}

.toast-icon {
  font-size: 32rpx;
}

.toast-message {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c3e50;
}

/* ===================================================
   7. 加载组件样式
   =================================================== */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  z-index: 10001;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-message {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

/* ===================================================
   8. 统计卡片组件样式
   =================================================== */
.stat-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.stat-card:active {
  transform: scale(0.95);
}

.stat-card-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.stat-card-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #2c3e50;
}

.stat-card-label {
  font-size: 24rpx;
  color: #95a5a6;
}

.stat-card-trend {
  font-size: 22rpx;
  font-weight: 600;
}

.stat-card-trend.up {
  color: #2ecc71;
}

.stat-card-trend.down {
  color: #e74c3c;
}

/* ===================================================
   9. 任务列表组件样式
   =================================================== */
.task-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.task-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.task-item:active {
  transform: scale(0.98);
}

.task-item.completed {
  opacity: 0.6;
}

.task-checkbox {
  font-size: 32rpx;
}

.task-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.task-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c3e50;
}

.task-description {
  font-size: 24rpx;
  color: #95a5a6;
}

.task-reward {
  font-size: 24rpx;
  font-weight: 600;
  color: #f39c12;
  background: rgba(243, 156, 18, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

/* ===================================================
   通用工具类
   =================================================== */

/* 渐变文字 */
.gradient-text {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 阴影层次 */
.shadow-sm {
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.shadow-md {
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.shadow-lg {
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
}

.shadow-glow {
  box-shadow: 0 0 40rpx rgba(102, 126, 234, 0.3);
}

/* 间距工具 */
.m-8 { margin: 8rpx; }
.m-16 { margin: 16rpx; }
.m-24 { margin: 24rpx; }
.m-32 { margin: 32rpx; }

.p-8 { padding: 8rpx; }
.p-16 { padding: 16rpx; }
.p-24 { padding: 24rpx; }
.p-32 { padding: 32rpx; }

/* 弹性布局 */
.flex { display: flex; }
.flex-center { 
  display: flex; 
  align-items: center; 
  justify-content: center; 
}
.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.flex-column {
  display: flex;
  flex-direction: column;
}

/* 网格布局 */
.grid { display: grid; }
.grid-2 { grid-template-columns: repeat(2, 1fr); }
.grid-3 { grid-template-columns: repeat(3, 1fr); }
.grid-4 { grid-template-columns: repeat(4, 1fr); }
