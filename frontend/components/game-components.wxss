/* ===================================================
   Leo Growth - 游戏化组件（微信风格）
   原则：简洁、有效、克制
   =================================================== */

/* 庆祝彩带 */
.confetti {
  position: fixed;
  width: 12rpx;
  height: 12rpx;
  top: -20rpx;
  z-index: 9999;
}

.confetti-red { background: #FA5151; }
.confetti-green { background: #07C160; }
.confetti-blue { background: #10AEFF; }
.confetti-orange { background: #FF9F00; }

/* 升级提示 */
.level-up {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 10000;
  background: #07C160;
  padding: 48rpx 64rpx;
  border-radius: 16rpx;
  text-align: center;
}

.level-up-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.level-up-from,
.level-up-to {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 进度条 */
.progress-bar-container {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.progress-bar-bg {
  flex: 1;
  height: 8rpx;
  background: #EEEEEE;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: #07C160;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-bar-text {
  font-size: 22rpx;
  color: #666666;
  min-width: 60rpx;
  text-align: right;
}

/* 徽章 */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.badge-primary {
  background: rgba(7, 193, 96, 0.1);
  color: #07C160;
}

.badge-warning {
  background: rgba(255, 159, 0, 0.1);
  color: #FF9F00;
}

.badge-error {
  background: rgba(250, 81, 81, 0.1);
  color: #FA5151;
}

/* 星星评分 */
.star-rating {
  display: flex;
  gap: 8rpx;
}

.star-rating .star {
  font-size: 32rpx;
  color: #FF9F00;
}

.star-rating .star.empty {
  color: #EEEEEE;
}

/* 连击计数器 */
.streak-counter {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #FF9F00 0%, #FF8800 100%);
  border-radius: 12rpx;
}

.streak-count {
  font-size: 48rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.streak-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 经验条 */
.xp-bar {
  position: relative;
  height: 8rpx;
  background: #EEEEEE;
  border-radius: 4rpx;
  overflow: hidden;
}

.xp-fill {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  background: #07C160;
  border-radius: 4rpx;
  transition: width 0.5s ease;
}

/* 奖励卡片 */
.reward-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
}

.reward-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.reward-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 8rpx;
}

.reward-amount {
  font-size: 32rpx;
  font-weight: 600;
  color: #07C160;
}

/* 动画类 */
@keyframes zoomIn {
  from { transform: scale(0.9); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.animate-pop {
  animation: zoomIn 0.2s ease;
}
